.4em] flex items-center gap-4\">\n              <Send className=\"h-5 w-5 text-white\" />\n              RAPID DISPATCH\n            </CardTitle>\n          </CardHeader>\n          <CardContent className=\"p-10 space-y-10\">\n            <p className=\"text-[10px] font-black uppercase tracking-widest text-mono-500 leading-relaxed\">\n              Transmit urgent institutional intelligence to all verified members via global communication nodes.\n            </p>\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n              <Button variant=\"outline\" className=\"h-auto py-10 flex flex-col gap-4 border-2 border-black rounded-none hover:bg-black hover:text-white transition-all group\" asChild>\n                <Link href=\"/admin/broadcast/new\">\n                  <Mail className=\"h-8 w-8 text-black group-hover:text-white\" />\n                  <span className=\"font-black uppercase tracking-[0.2em] text-[10px]\">EMAIL BROADCAST</span>\n                </Link>\n              </Button>\n              <Button variant=\"outline\" className=\"h-auto py-10 flex flex-col gap-4 border-2 border-black rounded-none hover:bg-black hover:text-white transition-all group\" asChild>\n                <Link href=\"/admin/broadcast/new\">\n                  <Smartphone className=\"h-8 w-8 text-black group-hover:text-white\" />\n                  <span className=\"font-black uppercase tracking-[0.2em] text-[10px]\">SMS BROADCAST</span>\n                </Link>\n              </Button>\n            </div>\n          </CardContent>\n          <CardFooter className=\"p-8 border-t-2 border-black bg-mono-50 flex justify-center\">\n            <Button variant=\"ghost\" className=\"text-[10px] font-black uppercase tracking-[0.3em] hover:bg-transparent hover:underline flex items-center gap-3\" asChild>\n              <Link href=\"/admin/broadcast/history\">\n                <History className=\"h-4 w-4\" />\n                VIEW BROADCAST ARCHIVE\n              </Link>\n            </Button>\n          </CardFooter>\n        </Card>\n\n        {/* Content Management Section */}\n        <Card className=\"border-4 border-black rounded-none shadow-none overflow-hidden bg-white\">\n          <CardHeader className=\"p-8 border-b-2 border-black\">\n            <CardTitle className=\"text-xs font-black uppercase tracking-[0.4em] flex items-center gap-4 text-black\">\n              <Layers className=\"h-5 w-5 text-black\" />\n              CONTENT HUB\n            </CardTitle>\n          </CardHeader>\n          <CardContent className=\"p-10 space-y-8\">\n            <p className=\"text-[10px] font-black uppercase tracking-widest text-mono-500 leading-relaxed\">\n              Maintain the institutional repository across all public-facing communication nodes.\n            </p>\n            <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-6\">\n              <Link href=\"/admin/content/news\" className=\"flex flex-col items-center gap-4 p-6 border-2 border-black hover:bg-black hover:text-white transition-all group\">\n                <Newspaper className=\"h-6 w-6\" />\n                <span className=\"text-[9px] font-black uppercase tracking-widest\">NEWS</span>\n              </Link>\n              <Link href=\"/admin/content/events\" className=\"flex flex-col items-center gap-4 p-6 border-2 border-black hover:bg-black hover:text-white transition-all group\">\n                <Calendar className=\"h-6 w-6\" />\n                <span className=\"text-[9px] font-black uppercase tracking-widest\">EVENTS</span>\n              </Link>\n              <Link href=\"/admin/content/jobs\" className=\"flex flex-col items-center gap-4 p-6 border-2 border-black hover:bg-black hover:text-white transition-all group\">\n                <Briefcase className=\"h-6 w-6\" />\n                <span className=\"text-[9px] font-black uppercase tracking-widest\">JOBS</span>\n              </Link>\n              <Link href=\"/admin/content/gallery\" cla