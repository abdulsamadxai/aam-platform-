-10 border-2 border-black rounded-none font-black uppercase tracking-widest text-[10px] hover:bg-black hover:text-white transition-all\">\n            <Download className=\"mr-3 h-5 w-5\" />\n            EXPORT DATA\n          </Button>\n          <Button className=\"h-16 px-10 bg-black text-white hover:bg-mono-800 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-black transition-all\" asChild>\n            <Link href=\"/admin/members/new\" className=\"flex items-center\">\n              <Plus className=\"mr-3 h-5 w-5\" />\n              APPEND REGISTRY\n            </Link>\n          </Button>\n        </div>\n      </div>\n\n      {/* Pending Applications Section */}\n      {applications && applications.length > 0 && (\n        <section className=\"space-y-12\">\n          <div className=\"flex items-center gap-6 border-b-4 border-black pb-4\">\n            <h2 className=\"text-3xl font-black uppercase tracking-tighter\">PENDING DOSSIERS</h2>\n            <Badge className=\"bg-black text-white font-black px-4 py-1.5 text-[10px] uppercase tracking-widest border-none rounded-none\">{applications.length} QUEUED</Badge>\n          </div>\n          \n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10\">\n            {applications.map((app) => (\n              <Card key={app.id} className=\"border-4 border-black rounded-none shadow-none hover:bg-mono-50 transition-all group overflow-hidden\">\n                <CardHeader className=\"p-8 border-b-2 border-black bg-mono-50\">\n                  <div className=\"flex justify-between items-start mb-6\">\n                    <Badge className=\"bg-black text-white rounded-none text-[9px] font-black uppercase tracking-widest border-none px-3 py-1\">\n                      {app.category_applied}\n                    </Badge>\n                    <span className=\"text-[9px] font-black uppercase tracking-widest text-mono-400\">\n                      LOGGED: {new Date(app.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }).toUpperCase()}\n                    </span>\n                  </div>\n                  <CardTitle className=\"text-2xl font-black uppercase tracking-tighter leading-none mb-2\">{app.applicant_name}</CardTitle>\n                  <CardDescription className=\"text-[10px] font-black text-black uppercase tracking-widest\">{app.email}</CardDescription>\n                </CardHeader>\n                <CardContent className=\"p-8\">\n                  <p className=\"text-[10px] font-black uppercase tracking-widest text-mono-500 leading-relaxed italic\">\n                    &quot;{app.notes || \"NO TECHNICAL NOTES PROVIDED.\"}&quot;\n                  </p>\n                </CardContent>\n                <CardFooter className=\"p-0\">\n                  <MemberInductionButtons applicationId={app.id} />\n                </CardFooter>\n              </Card>\n            ))}\n          </div>\n        </section>\n      )}\n\n      {/* Main Registry Section */}\n      <section className=\"space-y-12\">\n        <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-center gap-10\">\n          <h2 className=\"text-3xl font-black uppercase tracking-tighter border-b-4 border-black pb-4 lg:w-fit\">OFFICIAL REGISTRY</h2>\n          <div className=\"flex items-center gap-6 w-full lg:w-auto\">\n            <div className=\"relative flex-grow lg:w-96\">\n              <Search className=\"absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-black\" />\n              <Input placeholder=\"SEARCH REGISTRY INDEX...\" className=\"pl-14 border-2 border-black rounded-none h-14 font-black uppercase tracking-widest text-[10px] focus-visible:ring-0 placeholder:text-mono-300\" />\n            </div>\n            <Button variant=\"outline\" className=\"h-14 w-14 border-2 border-black rounded-none p-0 shrink-0 hover:bg-black hover:text-white transition-all\">\n              <Filter className=\