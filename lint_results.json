ing `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":139,"column":19,"nodeType":"JSXOpeningElement","endLine":139,"endColumn":157},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":172,"column":19,"nodeType":"JSXOpeningElement","endLine":172,"endColumn":141}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState, useEffect } from \"react\";\nimport { createClient } from \"@/lib/supabase/client\";\nimport { \n  Card, \n  CardContent, \n  CardHeader, \n  CardTitle,\n  CardFooter\n} from \"@/components/ui/card\";\nimport { Badge } from \"@/components/ui/badge\";\nimport { Button } from \"@/components/ui/button\";\nimport { Textarea } from \"@/components/ui/textarea\";\nimport { \n  User, \n  Clock, \n  MessageSquare, \n  ArrowUp,\n  Share2,\n  MoreVertical,\n  Loader2,\n  Send,\n  ArrowRight\n} from \"lucide-react\";\nimport DOMPurify from \"isomorphic-dompurify\";\n\ninterface ThreadViewProps {\n  initialThread: any;\n  initialReplies: any[];\n  currentUser: any;\n}\n\n/**\n * Thread View Component\n * BUG-050 FIX: Implemented XSS sanitization for thread body and replies using DOMPurify.\n * BUG-051 NOTE: Real-time subscriptions are enabled via Supabase Channels.\n */\nexport function ThreadView({ initialThread, initialReplies, currentUser }: ThreadViewProps) {\n  const [replies, setReplies] = useState(initialReplies);\n  const [newReply, setNewReply] = useState(\"\");\n  const [submitting, setSubmitting] = useState(false);\n  const supabase = createClient();\n\n  // Sanitize Markdown/HTML content\n  const sanitize = (content: string) => {\n    return DOMPurify.sanitize(content);\n  };\n\n  useEffect(() => {\n    const channel = supabase\n      .channel(`thread-${initialThread.id}`)\n      .on(\n        'postgres_changes',\n        {\n          event: 'INSERT',\n          schema: 'public',\n          table: 'forum_replies',\n          filter: `thread_id=eq.${initialThread.id}`,\n        },\n        async (payload) => {\n          const { data } = await supabase\n            .from(\"forum_replies\")\n            .select(\"*, author:members(full_name, profile_photo_url)\")\n            .eq(\"id\", payload.new.id)\n            .single();\n          \n          if (data) {\n            setReplies((current) => [...current, data]);\n          }\n        }\n      )\n      .subscribe();\n\n    return () => {\n      supabase.removeChannel(channel);\n    };\n  }, [initialThread.id, supabase]);\n\n  const handleSubmitReply = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newReply.trim()) return;\n\n    setSubmitting(true);\n    const { error } = await supabase\n      .from(\"forum_replies\")\n      .insert([\n        {\n          thread_id: initialThread.id,\n          author_id: currentUser.id,\n          body: newReply,\n        }\n      ]);\n\n    if (error) {\n      alert(\"Error posting reply: \" + error.message);\n    } else {\n      setNewReply(\"\");\n      // Update counts (optimistic or server-side trigger)\n      await supabase\n        .from(\"forum_threads\")\n        .update({ \n          last_reply_at: new Date().toISOString(),\n          reply_count: replies.length + 1\n        })\n        .eq(\"id\", initialThread.id);\n    }\n    setSubmitting(false);\n  };\n\n  return (\n    <div className=\"space-y-16\">\n      <Card className=\"border-4 border-black rounded-none shadow-none overflow-hidden bg-white\">\n        <CardHeader className=\"p-10 border-b-2 border-black bg-mono-50\">\n          <div className=\"flex items-center gap-6 mb-6\">\n            <Badge className=\"bg-black text-white rounded-none uppercase tracking-widest text-[9px] font-black border-none px-4 py-1.5\">\n              {initialThread.category}\n            </Badge>\n            <span className=\"text-[9px] font-black uppercase tracking-widest text-mono-400 flex items-center gap-2\">\n              <Clock className=\"h-3.5 w-3.5\" />\n              LOGGED: {new Date(initialThread.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).toUpperCase()}\n            </span>\n          </div>\n          <CardTitle className=\"text-4xl md:text-6xl font-black text-black leading-[0.95] uppercase tracking-tighter\">\n            {initialThread.title}\n          </CardTitle>\n        </CardHeader>\n        <CardContent className=\"p-10 space-y-12\">\n          {/* BUG-050 FIX: Sanitized content rendering */}\n          <div \n            className=\"prose prose-slate max-w-none text-black font-medium text-lg leading-relaxed whitespace-pre-wrap\"\n            dangerouslySetInnerHTML={{ __html: sanitize(initialThread.body) }}\n          />\n\n          <div className=\"flex flex-col md:flex-row items-start md:items-center justify-between pt-10 border-t-2 border-black gap-8\">\n            <div className=\"flex items-center gap-4\">\n              <div className=\"h-12 w-12 bg-mono-100 border-2 border-black flex items-center justify-center text-black font-black overflow-hidden\">\n                {initialThread.author?.profile_photo_url ? (\n                  <img src={initialThread.author.profile_photo_url} alt={initialThread.author.full_name} className=\"h-full w-full object-cover grayscale\" />\n                ) : (\n                  initialThread.author?.full_name?.charAt(0)\n                )}\n              </div>\n              <div>\n                <p className=\"text-xs font-black uppercase tracking-widest text-black\">{initialThread.author?.full_name}</p>\n                <p className=\"text-[9px] text-mono-400 uppercase font-bold tracking-[0.2em]\">ORIGINATOR / MEMBER</p>\n              </div>\n            </div>\n            <div className=\"flex items-center gap-6\">\n              <button className=\"text-[9px] font-black uppercase tracking-widest flex items-center gap-2 border-b-2 border-black pb-1 hover:text-mono-500 hover:border-mono-300 transition-all\">\n                <Share2 className=\"h-4 w-4\" />\n                DISTRIBUTE\n              </button>\n            </div>\n          </div>\n        </CardContent>\n      </Card>\n\n      <div className=\"space-y-12\">\n        <div className=\"flex items-center gap-6 border-b-4 border-black pb-4\">\n          <h2 className=\"text-3xl font-black uppercase tracking-tighter\">Peer Review</h2>\n          <span className=\"bg-black text-white font-black px-3 py-1 text-[10px] uppercase tracking-widest\">\n            {replies.length} REPLIES\n          </span>\n        </div>\n\n        <div className=\"space-y-8\">\n          {replies.map((reply) => (\n            <div key={reply.id} className=\"flex flex-col md:flex-row gap-6 group\">\n              <div className=\"h-12 w-12 bg-mono-100 border-2 border-black flex items-center justify-center text-black font-black shrink-0 overflow-hidden self-start\">\n                {reply.author?.profile_photo_url ? (\n                  <img src={reply.author.profile_photo_url} alt={reply.author.full_name} className=\"h-full w-full object-cover grayscale\" />\n                ) : (\n                  reply.author?.full_name?.charAt(0)\n                )}\n              </div>\n              <Card className=\"flex-grow border-2 border-black rounded-none shadow-none bg-white hover:bg-mono-50 transition-all overflow-hidden\">\n                <CardHeader className=\"p-6 border-b border-black/10 flex flex-row items-center justify-between\">\n                  <div className=\"flex items-center gap-3\">\n                    <span className=\"text-[10px] font-black uppercase tracking-widest text-black\">{reply.author?.full_name}</span>\n                    <span className=\"text-[9px] font-bold text-mono-400 uppercase tracking-widest\">\n                      ΓÇó {new Date(reply.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }).toUpperCase()}\n                    </span>\n                  </div>\n                </CardHeader>\n                <CardContent className=\"p-8\">\n                  {/* BUG-050 FIX: Sanitized reply rendering */}\n                  <div \n                    className=\"text-base text-black font-medium leading-relaxed whitespace-pre-wrap\"\n                    dangerouslySetInnerHTML={{ __html: sanitize(reply.body) }}\n                  />\n                </CardContent>\n              </Card>\n            </div>\n          ))}\n\n          {replies.length === 0 && (\n            <div className=\"py-24 text-center border-4 border-black border-dashed rounded-none bg-mono-50 space-y-6\">\n              <MessageSquare className=\"h-16 w-16 text-black mx-auto opacity-10\" />\n              <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">NO PEER DIALOGUE DETECTED.</p>\n            </div>\n          )}\n        </div>\n\n        <div className=\"pt-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none overflow-hidden bg-white\">\n            <CardHeader className=\"bg-black text-white p-6\">\n              <CardTitle className=\"text-[10px] font-black uppercase tracking-[0.4em] flex items-center gap-4\">\n                <MessageSquare className=\"h-5 w-5 text-white\" />\n                POST PEER REVIEW\n              </CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-0\">\n              <form onSubmit={handleSubmitReply}>\n                <Textarea \n                  placeholder=\"CONTRIBUTE TO THE ARCHITECTURAL DISCOURSE...\" \n                  className=\"border-none rounded-none focus-visible:ring-0 min-h-[200px] p-8 text-sm font-bold uppercase tracking-widest resize-none placeholder:text-mono-300\"\n                  value={newReply}\n                  onChange={(e) => setNewReply(e.target.value)}\n                />\n                <div className=\"p-8 bg-mono-50 border-t-2 border-black flex flex-col md:flex-row justify-between items-center gap-6\">\n                  <p className=\"text-[9px] font-black uppercase tracking-widest text-mono-400 max-w-sm leading-tight text-center md:text-left\">\n                    CONTRIBUTIONS MUST ADHERE TO THE INSTITUTIONAL CODE OF ETHICS. MARKDOWN IS ENABLED.\n                  </p>\n                  <Button \n                    type=\"submit\" \n                    disabled={submitting || !newReply.trim()}\n                    className=\"h-16 px-10 bg-black text-white hover:bg-mono-800 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-black transition-all group min-w-[200px]\"\n                  >\n                    {submitting ? (\n                      <Loader2 className=\"h-5 w-5 animate-spin\" />\n                    ) : (\n                      <>\n                        DISPATCH REPLY\n                        <ArrowRight className=\"ml-3 h-5 w-5 group-hover:translate-x-2 transition-transform\" />\n                      </>\n                    )}\n                  </Button>\n                </div>\n              </form>\n            </CardContent>\n          </Card>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\components\\layout\\Footer.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\components\\layout\\Navbar.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'activeDropdown' is assigned a value but never used.","line":75,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":75,"endColumn":24}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState, useEffect } from \"react\";\nimport Link from \"next/link\";\nimport { usePathname } from \"next/navigation\";\nimport { Menu, X, ChevronDown } from \"lucide-react\";\nimport { cn } from \"@/lib/utils\";\nimport { Logo } from \"@/components/shared/Logo\";\nimport { Button } from \"@/components/ui/button\";\n\nconst navConfig = [\n  { name: \"Home\", href: \"/\" },\n  {\n    name: \"About AAM\",\n    href: \"/about\",\n    children: [\n      { name: \"History & Background\", href: \"/about/history\" },\n      { name: \"Vision, Mission & Objectives\", href: \"/about/vision\" },\n      { name: \"Governing Council\", href: \"/about/council\" },\n      { name: \"Secretariat\", href: \"/about/secretariat\" },\n    ],\n  },\n  {\n    name: \"Registration\",\n    href: \"/registration\",\n    children: [\n      { name: \"Architect Registration\", href: \"/registration/architect\" },\n      { name: \"Registration Renewal\", href: \"/registration/renewal\" },\n      { name: \"Verification of License\", href: \"/registration/verification\" },\n      { name: \"Fee Structure\", href: \"/registration/fees\" },\n    ],\n  },\n  {\n    name: \"Regulations\",\n    href: \"/regulations\",\n    children: [\n      { name: \"Building Regulations\", href: \"/regulations/building\" },\n      { name: \"Code of Conduct\", href: \"/regulations/conduct\" },\n      { name: \"Relevant Legislation\", href: \"/regulations/legislation\" },\n    ],\n  },\n  {\n    name: \"Members\",\n    href: \"/members\",\n    children: [\n      { name: \"Member Directory\", href: \"/members\" },\n      { name: \"Registered Firms\", href: \"/members/firms\" },\n      { name: \"Honorary Members\", href: \"/members/honorary\" },\n    ],\n  },\n  {\n    name: \"Events & News\",\n    href: \"/news\",\n    children: [\n      { name: \"Upcoming Events\", href: \"/news/events\" },\n      { name: \"News & Announcements\", href: \"/news\" },\n      { name: \"Gallery\", href: \"/gallery\" },\n    ],\n  },\n  {\n    name: \"Resources\",\n    href: \"/resources\",\n    children: [\n      { name: \"Downloads & Forms\", href: \"/resources/downloads\" },\n      { name: \"Publications\", href: \"/resources/publications\" },\n      { name: \"Links\", href: \"/resources/links\" },\n    ],\n  },\n  { name: \"Contact Us\", href: \"/contact\" },\n];\n\nexport function Navbar() {\n  const [isOpen, setIsOpen] = useState(false);\n  const [scrolled, setScrolled] = useState(false);\n  const [activeDropdown, setActiveDropdown] = useState<string | null>(null);\n  const pathname = usePathname();\n\n  useEffect(() => {\n    const handleScroll = () => setScrolled(window.scrollY > 50);\n    window.addEventListener(\"scroll\", handleScroll);\n    return () => window.removeEventListener(\"scroll\", handleScroll);\n  }, []);\n\n  return (\n    <header\n      className={cn(\n        \"fixed top-0 left-0 right-0 z-50 transition-all duration-500 border-b\",\n        scrolled \n          ? \"bg-aam-navy/95 backdrop-blur-md py-3 border-aam-gold/20\" \n          : \"bg-aam-navy py-6 border-transparent\"\n      )}\n    >\n      <div className=\"container flex items-center justify-between\">\n        <Link href=\"/\" className=\"transition-transform duration-300 hover:scale-105\">\n          <Logo variant=\"sand\" className=\"scale-90\" />\n        </Link>\n\n        {/* Desktop Navigation */}\n        <nav className=\"hidden lg:flex items-center gap-1\">\n          {navConfig.map((item) => (\n            <div\n              key={item.name}\n              className=\"relative group\"\n              onMouseEnter={() => setActiveDropdown(item.name)}\n              onMouseLeave={() => setActiveDropdown(null)}\n            >\n              <Link\n                href={item.href}\n                className={cn(\n                  \"px-4 py-2 text-[13px] font-sans font-medium uppercase tracking-widest transition-all duration-300 flex items-center gap-1.5 border-b-2 border-transparent\",\n                  pathname === item.href || pathname.startsWith(item.href + \"/\")\n                    ? \"text-aam-teal border-aam-teal\"\n                    : \"text-aam-sand hover:text-aam-teal\"\n                )}\n              >\n                {item.name}\n                {item.children && <ChevronDown className=\"h-3 w-3 opacity-50 group-hover:rotate-180 transition-transform\" />}\n              </Link>\n\n              {item.children && (\n                <div className=\"absolute top-full left-0 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300\">\n                  <div className=\"bg-aam-navy border border-aam-gold/20 shadow-2xl min-w-[240px] overflow-hidden\">\n                    {item.children.map((child) => (\n                      <Link\n                        key={child.name}\n                        href={child.href}\n                        className=\"block px-6 py-4 text-[11px] font-sans font-medium uppercase tracking-[0.2em] text-aam-sand/70 hover:text-aam-teal hover:bg-aam-sand/5 transition-all border-b border-aam-gold/5 last:border-0\"\n                      >\n                        {child.name}\n                      </Link>\n                    ))}\n                  </div>\n                </div>\n              )}\n            </div>\n          ))}\n        </nav>\n\n        {/* Action Buttons */}\n        <div className=\"hidden lg:flex items-center gap-6\">\n          <Button \n            variant=\"outline\" \n            className=\"rounded-none border-aam-teal text