                 </TableRow>\n                  ))\n                )}\n              </TableBody>\n            </Table>\n          </div>\n        </div>\n\n        <div className=\"space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none bg-white\">\n            <CardHeader className=\"border-b-2 border-black bg-mono-50 p-8\">\n              <CardTitle className=\"text-[10px] font-black uppercase tracking-[0.4em]\">PORTAL METRICS</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-8 space-y-10\">\n              <div className=\"space-y-2\">\n                <p className=\"text-[9px] font-black uppercase tracking-widest text-mono-400\">TOTAL POSTINGS</p>\n                <p className=\"text-5xl font-black tracking-tighter\">{jobs.length}</p>\n              </div>\n              <div className=\"space-y-2\">\n                <p className=\"text-[9px] font-black uppercase tracking-widest text-mono-400\">ACTIVE LISTINGS</p>\n                <p className=\"text-5xl font-black tracking-tighter\">{jobs.filter(j => j.is_active).length}</p>\n              </div>\n              <div className=\"p-6 bg-black text-white rounded-none border-2 border-black\">\n                <p className=\"text-[9px] font-black uppercase tracking-widest leading-relaxed\">\n                  MAINTAIN THE PROFESSIONAL OPPORTUNITY ARCHIVE. ENSURE ALL FIRM DATA IS VERIFIED BEFORE TRANSMISSION.\n                </p>\n              </div>\n            </CardContent>\n          </Card>\n\n          <div className=\"p-8 border-4 border-black border-dashed rounded-none space-y-6 text-center bg-mono-50\">\n            <Briefcase className=\"h-10 w-10 text-black mx-auto opacity-20\" />\n            <h4 className=\"text-[10px] font-black uppercase tracking-[0.4em]\">VACANCY PROTOCOL</h4>\n            <p className=\"text-[9px] font-black uppercase tracking-widest leading-relaxed text-mono-500\">\n              LISTINGS AUTOMATICALLY SYNC TO PUBLIC