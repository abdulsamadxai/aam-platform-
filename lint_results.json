e icon imports to prevent build errors.\n * BUG-030 FIX: Added explicit server-side role check (defense in depth).\n */\nexport default async function AdminDashboardPage() {\n  const supabase = await createClient();\n  \n  // 1. Verify Admin Authority (Defense in depth beyond middleware)\n  const { data: { user } } = await supabase.auth.getUser();\n  if (!user || user.app_metadata?.role !== 'admin') {\n    redirect(\"/dashboard\");\n  }\n\n  // 2. Fetch Stats in Parallel\n  const [\n    { count: memberCount },\n    { count: pendingApps },\n    { count: threadCount },\n    { count: broadcastCount }\n  ] = await Promise.all([\n    supabase.from(\"members\").select(\"*\", { count: \"exact\", head: true }),\n    supabase.from(\"registration_applications\").select(\"*\", { count: \"exact\", head: true }).eq(\"status\", \"pending\"),\n    supabase.from(\"forum_threads\").select(\"*\", { count: \"exact\", head: true }), // FIX: changed from non-existent discussion_threads\n    supabase.from(\"broadcasts\").select(\"*\", { count: \"exact\", head: true })\n  ]);\n\n  const stats = [\n    { label: \"REGISTERED MEMBERS\", value: memberCount || 0, icon: Users },\n    { label: \"PENDING APPLICATIONS\", value: pendingApps || 0, icon: UserPlus },\n    { label: \"ACTIVE DISCOURSES\", value: threadCount || 0, icon: MessageSquare },\n    { label: \"BROADCASTS DISPATCHED\", value: broadcastCount || 0, icon: Send },\n  ];\n\n  return (\n    <div className=\"container py-24 space-y-24\">\n      <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-end gap-12 border-b-8 border-black pb-12\">\n        <div className=\"space-y-4\">\n          <h1 className=\"text-5xl md:text-8xl font-black uppercase tracking-tighter leading-none\">Command <br /> Center</h1>\n          <p className=\"text-sm font-black uppercase tracking-[0.4em] text-mono-400\">Institutional Platform Oversight</p>\n        </div>\n        <div className=\"flex flex-wrap gap-6\">\n          <Button 