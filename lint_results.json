ext-xs font-bold text-mono-500 uppercase tracking-tight\">\n                  <Phone className=\"h-4 w-4 shrink-0 text-black\" />\n                  <span>{firm.phone}</span>\n                </div>\n              )}\n              {firm.email && (\n                <div className=\"flex items-center gap-3 text-xs font-bold text-black uppercase tracking-tight\">\n                  <Mail className=\"h-4 w-4 shrink-0 text-black\" />\n                  <a href={`mailto:${firm.email}`} className=\"hover:underline underline-offset-4 decoration-2\">\n                    {firm.email}\n                  </a>\n                </div>\n              )}\n            </CardContent>\n            <CardFooter className=\"pb-8\">\n              {firm.website ? (\n                <a \n                  href={firm.website} \n                  target=\"_blank\" \n                  rel=\"noopener noreferrer\"\n                  className=\"w-full inline-flex items-center justify-center gap-2 py-4 bg-black text-white text-[10px] font-black uppercase tracking-widest hover:bg-mono-800 transition-colors\"\n                >\n                  <Globe className=\"h-3 w-3\" />\n                  Visit Office Website <ArrowUpRight className=\"h-3 w-3\" />\n                </a>\n              ) : (\n                <div className=\"w-full py-4 text-center text-[10px] font-black uppercase tracking-widest text-mono-400 border border-black/10\">\n                  No Digital Portfolio\n                </div>\n              )}\n            </CardFooter>\n          </Card>\n        ))}\n\n        {(!firms || firms.length === 0) && (\n          <div className=\"col-span-full py-24 text-center text-mono-400 font-black uppercase tracking-[0.3em] border-[4px] border-black border-dashed\">\n            Registry Archive Empty.\n          </div>\n        )}\n      </div>\n\n      <div className=\"bg-black text-white p-12 md:p-24 space-y-12 relative overflow-hidden\">\n        <div className=\"absolute top-0 