id-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12\">\n        {programmes?.map((prog) => (\n          <Card key={prog.id} className=\"flex flex-col border-2 border-black rounded-none shadow-none bg-white hover:bg-mono-50 transition-all\">\n            <CardHeader className=\"border-b-2 border-black pb-8\">\n              <div className=\"flex justify-between items-start mb-6\">\n                <Badge className=\"bg-black text-white rounded-none text-[10px] font-black uppercase tracking-[0.2em] px-3 py-1 border-none\">\n                  {prog.status}\n                </Badge>\n                <span className=\"text-3xl font-black tracking-tighter text-black uppercase\">\n                  {prog.cost === 0 ? \"FREE\" : `MVR ${prog.cost}`}\n                </span>\n              </div>\n              <CardTitle className=\"text-2xl font-black leading-none tracking-tighter uppercase\">\n                {prog.title}\n              </CardTitle>\n            </CardHeader>\n            <CardContent className=\"flex-grow py-8 space-y-8\">\n              <CardDescription className=\"text-mono-600 font-medium line-clamp-3 text-base\">\n                {prog.description}\n              </CardDescription>\n              \n              <div className=\"space-y-4 pt-4 border-t border-black/10\">\n                <div className=\"flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-black\">\n                  <Calendar className=\"h-4 w-4\" />\n                  <span>STARTING: {new Date(prog.start_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>\n                </div>\n                <div className=\"flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-black\">\n                  <Clock className=\"h-4 w-4\" />\n                  <span>DURATION: {prog.duration}</span>\n                </div>\n                <div className=\"flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-black\">\n                  <User className=\"h-4 w-4\" />\n                  <span>FACILITATOR: {prog.facilitator}</span>\n                </div>\n              </div>\n            </CardContent>\n            <CardFooter className=\"p-8 border-t-2 border-black\">\n              <Button asChild className=\"w-full h-14 bg-black text-white hover:bg-white hover:text-black border-2 border-black font-black uppercase tracking-widest text-xs rounded-none transition-all group\">\n                <Link href={`/training/${prog.id}`}>\n                  COURSE DOSSIER\n                  <ArrowRight className=\"ml-2 h-4 w-4 group-hover:translate-x-2 transition-transform\" />\n                </Link>\n              </Button>\n            </CardFooter>\n          </Card>\n        ))}\n      </div>\n\n      <div className=\"bg-black text-white p-12 md:p-24 space-y-12 relative overflow-hidden\">\n        <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:40px_40px]\" />\n        <div className=\"max-w-3xl space-y-8 relative z-10\">\n          <h2 className=\"text-4xl md:text-7xl font-black uppercase tracking-tighter leading-none\">Continuous <br /> Professional <br /> Development</h2>\n          <p className=\"text-xl text-mono-400 font-medium leading-tight max-w-xl\">\n            Attending AAM certified training programmes earns you CPD points required \n            for professional membership renewal. Track your progress via the dashboard.\n          </p>\n          <div className=\"flex flex-wrap gap-8 pt-8\">\n            <button className=\"text-sm font-black uppercase tracking-[0.3em] border-b-2 border-white pb-2 hover:text-mono-300 transition-colors\">\n              CPD GUIDE 2026\n            </button>\n            <button className=\"text-sm font-black uppercase tracking-[0.3em] border-b-2 border-white pb-2 hover:text-mono-300 transition-colors\">\n              ENROLMENT FAQ\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\api\\auth\\callback\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\api\\broadcast\\dispatch\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'data' is assigned a value but never used.","line":111,"column":17,"nodeType":"Identifier","messageId":"unusedVar","endLine":111,"endColumn":21},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":155,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":155,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[5399,5402],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[5399,5402],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createClient } from \"@/lib/supabase/server\";\nimport { NextResponse } from \"next/server\";\nimport { resend, EMAIL_FROM } from \"@/lib/resend\";\nimport { twilioClient, SMS_FROM } from \"@/lib/twilio\";\nimport { broadcastSchema } from \"@/lib/validations\";\nimport BroadcastEmail from \"@/emails/BroadcastEmail\";\nimport * as React from \"react\";\n\n/**\n * Broadcast Dispatch Route\n * BUG-020 FIX: Uses Resend Batch API for privacy and efficiency (no 'to' array leaks).\n * BUG-021 FIX: Corrected Postgres column names (message -> body, recipient_count -> sent_count).\n * BUG-022 FIX: Creates the broadcast record BEFORE starting transmission.\n * BUG-023 FIX: Added Zod schema validation for all inputs.\n * BUG-024 FIX: Properly handles 'test' category by targeting the current admin.\n * BUG-025 FIX: Sanitized error responses to prevent internal leakage.\n */\nexport async function POST(request: Request) {\n  try {\n    const supabase = await createClient();\n    \n    // 1. Verify Admin Authority\n    const { data: { user } } = await supabase.auth.getUser();\n    if (!user || user.app_metadata?.role !== 'admin') {\n      return NextResponse.json({ error: \"UNAUTHORIZED\" }, { status: 401 });\n    }\n\n    const body = await request.json();\n    \n    // BUG-023: Zod Validation\n    // Note: The UI currently sends 'message' and 'category', but the schema expects 'body' and 'recipient_filter'.\n    // We'll transform the UI input to match the schema.\n    const validatedData = broadcastSchema.parse({\n      type: body.type,\n      subject: body.subject,\n      body: body.message,\n      recipient_filter: {\n        category: body.category === 'all' || body.category === 'test' ? undefined : body.category,\n        all: body.category === 'all'\n      }\n    });\n\n    // 2. Fetch Recipient Registry\n    let query = supabase\n      .from(\"members\")\n      .select(\"email, phone\")\n      .eq(\"unsubscribed\", false)\n      .eq(\"status\", \"active\");\n\n    // BUG-024: Handle 'test' category (send only to the requesting admin)\n    if (body.category === 'test') {\n      query = query.eq(\"email\", user.email);\n    } else if (validatedData.recipient_filter.category) {\n      query = query.eq(\"category\", validatedData.recipient_filter.category);\n    }\n\n    const { data: recipients, error: fetchError } = await query;\n\n    if (fetchError || !recipients) {\n      return NextResponse.json({ error: \"REGISTRY_FETCH_FAILED\" }, { status: 500 });\n    }\n\n    const recipientCount = recipients.length;\n    if (recipientCount === 0) {\n      return NextResponse.json({ error: \"NO_RECIPIENTS_FOUND\" }, { status: 400 });\n    }\n\n    // BUG-022: Create record BEFORE sending\n    const { data: broadcastRecord, error: insertError } = await supabase\n      .from(\"broadcasts\")\n      .insert({\n        type: validatedData.type,\n        subject: validatedData.subject || 'Institutional Dispatch',\n        body: validatedData.body,\n        recipient_filter: validatedData.recipient_filter,\n        sent_count: 0,\n        fail_count: 0,\n        status: 'sending',\n        created_by: user.id\n      })\n      .select()\n      .single();\n\n    if (insertError || !broadcastRecord) {\n      return NextResponse.json({ error: \"ARCHIVE_INITIALIZATION_FAILED\" }, { status: 500 });\n    }\n\n    let successCount = 0;\n    let failureCount = 0;\n\n    // 3. Initiate Transmission\n    if (validatedData.type === 'email') {\n      const emailList = recipients.filter(r => r.email).map(r => r.email!);\n      \n      // BUG-020: Use Resend Batch API for privacy\n      // Batch limit is 100 per call, we'll process in chunks of 50\n      const CHUNK_SIZE = 50;\n      for (let i = 0; i < emailList.length; i += CHUNK_SIZE) {\n        const chunk = emailList.slice(i, i + CHUNK_SIZE);\n        const batch = chunk.map(email => ({\n          from: EMAIL_FROM,\n          to: email,\n          subject: validatedData.subject || \"AAM Institutional Dispatch\",\n          react: React.createElement(BroadcastEmail, {\n            subject: validatedData.subject || \"Institutional Dispatch\",\n            body: validatedData.body,\n            unsubscribeUrl: `${process.env.NEXT_PUBLIC_APP_URL}/unsubscribe?email=${email}`\n          })\n        }));\n\n        const { data, error } = await resend.batch.send(batch);\n        if (error) {\n          failureCount += chunk.length;\n        } else {\n          successCount += chunk.length;\n        }\n      }\n    } else if (validatedData.type === 'sms') {\n      // BUG-026: SMS throttling (concurrency control)\n      const phoneList = recipients.filter(r => r.phone).map(r => r.phone!);\n      \n      // Sequential processing for SMS to avoid Twilio rate limits\n      for (const phone of phoneList) {\n        try {\n          await twilioClient.messages.create({\n            body: validatedData.body,\n            from: SMS_FROM,\n            to: phone\n          });\n          successCount++;\n        } catch (e) {\n          console.error(`SMS failed for ${phone}:`, e);\n          failureCount++;\n        }\n      }\n    }\n\n    // 4. Update Final Status\n    await supabase\n      .from(\"broadcasts\")\n      .update({\n        sent_count: successCount,\n        fail_count: failureCount,\n        status: failureCount === 0 ? 'sent' : 'failed'\n      })\n      .eq(\"id\", broadcastRecord.id);\n\n    return NextResponse.json({ \n      success: true, \n      recipients: recipientCount,\n      dispatched: successCount,\n      failed: failureCount\n    });\n\n  } catch (error: any) {\n    // BUG-025: Sanitized error response\n    console.error(\"Broadcast transmission error:\", error);\n    \n    // Distinguish between validation errors and internal errors\n    if (error.name === 'ZodError') {\n      return NextResponse.json({ error: \"INVALID_PARAMETERS\", details: error.errors }, { status: 400 });\n    }\n\n    return NextResponse.json({ error: \"INTERNAL_TRANSMISSION_ERROR\" }, { status: 500 });\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\api\\contact\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":43,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":43,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1252,1255],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1252,1255],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createClient } from \"@/lib/supabase/server\";\nimport { NextResponse } from \"next/server\";\nimport { contactSchema } from \"@/lib/validations\";\n\n/**\n * Contact Submission API\n * BUG-029 FIX: Implemented missing contact submission handler with Zod validation.\n * Uses public service role bypass for initial insertion as RLS allows public inserts.\n */\nexport async function POST(request: Request) {\n  try {\n    const body = await request.json();\n    \n    // Validate Input\n    const validatedData = contactSchema.parse(body);\n\n    const supabase = await createClient();\n\n    const { data, error } = await supabase\n      .from(\"contact_submissions\")\n      .insert({\n        name: validatedData.name,\n        email: validatedData.email,\n        subject: validatedData.subject || \"No Subject\",\n        body: validatedData.body,\n        is_anonymous: validatedData.is_anonymous,\n        status: \"pending\"\n      })\n      .select()\n      .single();\n\n    if (error) {\n      console.error(\"Contact submission DB error:\", error);\n      return NextResponse.json({ error: \"SUBMISSION_FAILED\" }, { status: 500 });\n    }\n\n    return NextResponse.json({ \n      success: true, \n      id: data.id,\n      message: \"COMMUNICATION_RECEIVED\"\n    });\n\n  } catch (error: any) {\n    console.error(\"Contact API error:\", error);\n    if (error.name === 'ZodError') {\n      return NextResponse.json({ error: \"INVALID_INPUT\", details: error.errors }, { status: 400 });\n    }\n    return NextResponse.json({ error: \"INTERNAL_ERROR\" }, { status: 500 });\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\api\\forum\\threads\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used.","line":31,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":31,"endColumn":17},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":62,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":62,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1726,1729],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1726,1729],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createClient } from \"@/lib/supabase/server\";\nimport { NextResponse } from \"next/server\";\nimport { createThreadSchema } from \"@/lib/validations\";\n\n/**\n * Forum Threads API\n * BUG-028 FIX: Implemented missing forum thread creation and retrieval API.\n * Enforces authentication and Zod validation.\n */\nexport async function GET(request: Request) {\n  try {\n    const { searchParams } = new URL(request.url);\n    const category = searchParams.get(\"category\");\n    const supabase = await createClient();\n\n    let query = supabase\n      .from(\"forum_threads\")\n      .select(\"*, members:author_id(full_name, profile_photo_url)\")\n      .is(\"deleted_at\", null)\n      .order(\"created_at\", { ascending: false });\n\n    if (category && category !== 'all') {\n      query = query.eq(\"category\", category);\n    }\n\n    const { data, error } = await query;\n\n    if (error) throw error;\n\n    return NextResponse.json(data);\n  } catch (error) {\n    return NextResponse.json({ error: \"FETCH_FAILED\" }, { status: 500 });\n  }\n}\n\nexport async function POST(request: Request) {\n  try {\n    const supabase = await createClient();\n    const { data: { user } } = await supabase.auth.getUser();\n\n    if (!user) {\n      return NextResponse.json({ error: \"UNAUTHORIZED\" }, { status: 401 });\n    }\n\n    const body = await request.json();\n    const validatedData = createThreadSchema.parse(body);\n\n    const { data, error } = await supabase\n      .from(\"forum_threads\")\n      .insert({\n        title: validatedData.title,\n        body: validatedData.body,\n        category: validatedData.category,\n        author_id: user.id\n      })\n      .select()\n      .single();\n\n    if (error) throw error;\n\n    return NextResponse.json(data);\n  } catch (error: any) {\n    if (error.name === 'ZodError') {\n      return NextResponse.json({ error: \"INVALID_INPUT\", details: error.errors }, { status: 400 });\n    }\n    return NextResponse.json({ error: \"THREAD_CREATION_FAILED\" }, { status: 500 });\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\not-found.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\components\\admin\\MemberInductionButtons.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fi