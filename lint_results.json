rd({\n      email,\n      password,\n    });\n\n    if (error) {\n      setMessage({ type: 'error', text: error.message });\n    } else {\n      router.push(\"/dashboard\");\n    }\n    setLoading(false);\n  };\n\n  const handleMagicLink = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setLoading(true);\n    setMessage(null);\n\n    const { error } = await supabase.auth.signInWithOtp({\n      email,\n      options: {\n        // BUG-017 FIX: Must match the API route at /api/auth/callback\n        emailRedirectTo: `${window.location.origin}/api/auth/callback`,\n      },\n    });\n\n    if (error) {\n      setMessage({ type: 'error', text: error.message });\n    } else {\n      setMessage({ type: 'success', text: \"Verification link dispatched to your inbox.\" });\n    }\n    setLoading(false);\n  };\n\n  return (\n    <div className=\"container min-h-[90vh] flex items-center justify-center py-24\">\n      <div className=\"w-full max-w-md space-y-12\">\n        <div className=\"space-y-4 border-l-8 border-black pl-8\">\n          <h1 className=\"font-display text-5xl font-black uppercase tracking-tighter leading-none\">Access <br /> Portal</h1>\n          <p className=\"text-sm font-bold text-mono-500 uppercase tracking-widest\">Architects Association Maldives</p>\n        </div>\n\n        <Card className=\"border-4 border-black rounded-none shadow-none overflow-hidden bg-white\">\n          <Tabs defaultValue=\"password\" title=\"Login Method\">\n            <CardHeader className=\"p-0 border-b-2 border-black\">\n              <TabsList className=\"grid w-full grid-cols-2 bg-white rounded-none h-14 p-0\">\n                <TabsTrigger \n                  value=\"password\" \n                  className=\"rounded-none h-full data-[state=active]:bg-black data-[state=active]:text-white font-black uppercase tracking-widest text-[10px]\"\n                >\n                  PASSWORD\n                </TabsTrigger>\n                <TabsTrigger \n                  value=\"magic\" \n                  className=\"rounded-none h-full data-[state=active]:bg-black data-[state=active]:text-white font-black uppercase tracking-widest text-[10px]\"\n                >\n                  MAGIC LINK\n                </TabsTrigger>\n              </TabsList>\n            </CardHeader>\n            \n            <CardContent className=\"p-10\">\n              {message && (\n                <div className={`p-6 rounded-none mb-8 text-[10px] font-black uppercase tracking-widest flex items-start gap-4 border-2 ${\n                  message.type === 'success' \n                  ? 'bg-black text-white border-black' \n                  : 'bg-white text-black border-black'\n                }`}>\n                  <div className=\"mt-0.5\">\n                    {message.type === 'success' ? 'LOG:' : 'ERR:'}\n                  </div>\n                  <p>{message.text}</p>\n                </div>\n              )}\n\n              <TabsContent value=\"password\" name=\"password-login\">\n                <form onSubmit={handlePasswordLogin} className=\"space-y-6\">\n                  <div className=\"space-y-2\">\n                    <Label htmlFor=\"email\" className=\"text-[10px] font-black uppercase tracking-[0.2em]\">IDENTIFIER (EMAIL)</Label>\n                    <div className=\"relative\">\n                      <Mail className=\"absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-black\" />\n                      <Input \n                        id=\"email\" \n                        type=\"email\" \n                        placeholder=\"ENTER REGISTERED EMAIL\" \n                        className=\"pl-12 h-14 border-2 border-black rounded-none font-bold uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300\"\n                        value={email}\n                        onChange={(e) => setEmail(e.target.value)}\n                        required\n                      />\n                    </div>\n                  </div>\n                  <div className=\"space-y-2\">\n                    <div className=\"flex justify-between items-center\">\n                      <Label htmlFor=\"password\" className=\"text-[10px] font-black uppercase tracking-[0.2em]\">SECURITY KEY</Label>\n                      <button type=\"button\" className=\"text-[8px] font-black uppercase tracking-widest hover:underline\">\n                        RECOVER ACCESS\n                      </button>\n                    </div>\n                    <div className=\"relative\">\n                      <Lock className=\"absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-black\" />\n                      <Input \n                        id=\"password\" \n                        type=\"password\" \n                        placeholder=\"ΓÇóΓÇóΓÇóΓÇóΓÇóΓÇóΓÇóΓÇó\" \n                        className=\"pl-12 h-14 border-2 border-black rounded-none font-bold uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300\"\n                        value={password}\n                        onChange={(e) => setPassword(e.target.value)}\n                        required\n                      />\n                    </div>\n                  </div>\n                  <Button \n                    type=\"submit\" \n                    className=\"w-full bg-black text-white hover:bg-mono-800 font-black uppercase tracking-[0.3em] h-16 rounded-none transition-all group text-xs border-2 border-black\"\n                    disabled={loading}\n                  >\n                    {loading ? (\n                      <Loader2 className=\"h-5 w-5 animate-spin\" />\n                    ) : (\n                      <>\n                        AUTHENTICATE\n                        <ArrowRight className=\"ml-3 h-4 w-4 group-hover:translate-x-2 transition-transform\" />\n                      </>\n                    )}\n                  </Button>\n                </form>\n              </TabsContent>\n\n              <TabsContent value=\"magic\" name=\"magic-login\">\n                <form onSubmit={handleMagicLink} className=\"space-y-6\">\n                  <div className=\"space-y-2\">\n                    <Label htmlFor=\"magic-email\" className=\"text-[10px] font-black uppercase tracking-[0.2em]\">IDENTIFIER (EMAIL)</Label>\n                    <div className=\"relative\">\n                      <Mail className=\"absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-black\" />\n                      <Input \n                        id=\"magic-email\" \n                        type=\"email\" \n                        placeholder=\"ENTER REGISTERED EMAIL\" \n                        className=\"pl-12 h-14 border-2 border-black rounded-none font-bold uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300\"\n                        value={email}\n                        onChange={(e) => setEmail(e.target.value)}\n                        required\n                      />\n                    </div>\n                    <p className=\"text-[9px] font-bold text-mono-400 uppercase tracking-widest leading-tight pt-2\">\n                      A unique login token will be transmitted to your verified email address.\n                    </p>\n                  </div>\n                  <Button \n                    type=\"submit\" \n                    className=\"w-full bg-black text-white hover:bg-mono-800 font-black uppercase tracking-[0.3em] h-16 rounded-none transition-all group text-xs border-2 border-black\"\n                    disabled={loading}\n                  >\n                    {loading ? (\n                      <Loader2 className=\"h-5 w-5 animate-spin\" />\n                    ) : (\n                      <>\n                        DISPATCH TOKEN\n                        <Sparkles className=\"ml-3 h-4 w-4\" />\n                      </>\n                    )}\n                  </Button>\n                </form>\n              </TabsContent>\n            </CardContent>\n          </Tabs>\n\n          <CardFooter className=\"bg-mono-50 p-10 flex flex-col gap-6 text-center border-t-2 border-black\">\n            <p className=\"text-[10px] font-black uppercase tracking-widest text-mono-500\">\n              NO ACCOUNT DETECTED?\n            </p>\n            <Button variant=\"outline\" className=\"w-full h-14 border-2 border-black rounded-none font-black uppercase tracking-[0.2em] text-xs hover:bg-black hover:text-white transition-all\" asChild>\n              <a href=\"/register\">ENROLL IN ASSOCIATION</a>\n            </Button>\n          </CardFooter>\n        </Card>\n\n        <p className=\"text-center text-[9px] font-bold text-mono-400 uppercase tracking-[0.3em] leading-relaxed px-8\">\n          By authenticating, you adhere to the AAM <a href=\"#\" className=\"text-black underline decoration-2\">Regulatory Framework</a> and <a href=\"#\" className=\"text-black underline decoration-2\">Data Protection Policy</a>.\n        </p>\n      </div>\n    </div>\n  );\n}\n\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\members\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Filter' is defined but never used.","line":14,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":14,"endColumn":9,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Filter"},"fix":{"range":[290,301],"text":""},"desc":"Remove unused variable \"Filter\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Link' is defined but never used.","line":20,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":20,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Link"},"fix":{"range":[429,459],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createClient } from \"@/lib/supabase/server\";\nimport { \n  Table, \n  TableBody, \n  TableCell, \n  TableHead, \n  TableHeader, \n  TableRow \n} from \"@/components/ui/table\";\nimport { Input } from \"@/components/ui/input\";\nimport { Button } from \"@/components/ui/button\";\nimport { \n  Search, \n  Filter, \n  ShieldCheck,\n  Globe\n} from \"lucide-react\";\nimport { Badge } from \"@/components/ui/badge\";\nimport Image from \"next/image\";\nimport Link from \"next/link\";\n\n/**\n * Member Directory Page (Public)\n * BUG-032 FIX: Converted to Server Component for SSR/SEO and security.\n * BUG-037 FIX: Data is fetched server-side with explicit safe column selection.\n * BUG-035 FIX: Dynamic \"Member Since\" date using joined_at field.\n * BUG-059 FIX: Using next/image for profile photos.\n */\nexport default async function MemberDirectoryPage({\n  searchParams,\n}: {\n  searchParams: Promise<{ q?: string }>;\n}) {\n  const query = (await searchParams).q || \"\";\n  const supabase = await createClient();\n\n  // Fetch only safe columns for public consumption\n  let dbQuery = supabase\n    .from(\"members\")\n    .select(\"id, aam_id, full_name, category, status, profile_photo_url, firm_name, joined_at\")\n    .eq(\"status\", \"active\")\n    .order(\"full_name\");\n\n  if (query) {\n    dbQuery = dbQuery.or(`full_name.ilike.%${query}%,aam_id.ilike.%${query}%`);\n  }\n\n  const { data: members, error } = await dbQuery;\n\n  if (error) {\n    console.error(\"Error fetching members:\", error);\n  }\n\n  const memberList = members || [];\n\n  return (\n    <div className=\"container py-32 max-w-7xl space-y-24\">\n      {/* Header section */}\n      <div className=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-12 border-b-8 border-black pb-12\">\n        <div className=\"space-y-4 border-l-8 border-black pl-8\">\n          <h1 className=\"text-6xl md:text-9xl font-black uppercase tracking-tighter leading-none\">Member <br /> Registry</h1>\n          <p className=\"text-sm font-black uppercase tracking-[0.4em] text-mono-400 italic\">The Official Archive of Architecture in Maldives</p>\n        </div>\n        <div className=\"p-8 border-4 border-black bg-black text-white flex flex-col gap-2\">\n          <span className=\"text-[10px] font-black uppercase tracking-[0.4em]\">VERIFIED NODES</span>\n          <span className=\"text-5xl font-black tracking-tighter\">{memberList.length}</span>\n        </div>\n      </div>\n\n      {/* Controls - Server side search using a form */}\n      <form action=\"/members\" method=\"GET\" className=\"flex flex-col md:flex-row gap-6\">\n        <div className=\"relative flex-grow\">\n          <Search className=\"absolute left-6 top-1/2 -translate-y-1/2 h-6 w-6 text-black\" />\n          <Input \n            name=\"q\"\n            defaultValue={query}\n            placeholder=\"SEARCH REGISTRY BY NAME OR AAM-ID...\" \n            className=\"h-20 pl-16 pr-8 border-4 border-black rounded-none font-black uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300 shadow-[8px_8px_0px_0px_rgba(0,0,0,0.1)]\"\n          />\n        </div>\n        <Button type=\"submit\" className=\"h-20 px-12 bg-black text-white hover:bg-mono-800 rounded-none border-4 border-black font-black uppercase tracking-widest text-[10px] shadow-[8px_8px_0px_0px_rgba(0,0,0,0.1)] transition-all\">\n          INITIATE SEARCH\n        </Button>\n      </form>\n\n      {/* Directory Table */}\n      <div className=\"border-4 border-black bg-white overflow-hidden shadow-[16px_16px_0px_0px_rgba(0,0,0,0.1)]\">\n        <Table>\n          <TableHeader>\n            <TableRow className=\"bg-black hover:bg-black border-none\">\n              <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-20 pl-10\">Institutional Identity</TableHead>\n              <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-20\">Registry ID</TableHead>\n              <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-20\">Classification</TableHead>\n              <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-20 hidden lg:table-cell\">Professional Firm</TableHead>\n              <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-20 text-right pr-10\">Verification</TableHead>\n            </TableRow>\n          </TableHeader>\n          <TableBody>\n            {memberList.length === 0 ? (\n              <TableRow>\n                <TableCell colSpan={5} className=\"h-96 text-center\">\n                  <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">NO MATCHING RECORDS FOUND IN ARCHIVE.</p>\n                </TableCell>\n              </TableRow>\n            ) : (\n              memberList.map((member) => (\n                <TableRow key={member.id} className=\"border-b-2 border-black/10 last:border-none hover:bg-mono-50 transition-colors group\">\n                  <TableCell className=\"pl-10 py-10\">\n                    <div className=\"flex items-center gap-6\">\n                      <div className=\"h-16 w-16 border-4 border-black rounded-none bg-white relative flex items-center justify-center text-xl font-black overflow-hidden group-hover:bg-black group-hover:text-white transition-all\">\n                        {member.profile_photo_url ? (\n                          <Image \n                            src={member.profile_photo_url} \n                            alt={member.full_name} \n                            fill\n                            className=\"object-cover grayscale\" \n                          />\n                        ) : (\n                          member.full_name.charAt(0)\n                        )}\n                      </div>\n                      <div className=\"space-y-1\">\n                        <p className=\"text-lg font-black uppercase tracking-tight group-hover:underline decoration-4 underline-offset-4\">{member.full_name}</p>\n                        <p className=\"text-[9px] font-bold text-mono-400 uppercase tracking-widest\">\n                          ACTIVE MEMBER SINCE {member.joined_at ? new Date(member.joined_at).getFullYear() : '2026'}\n                        </p>\n                      </div>\n                    </div>\n                  </TableCell>\n                  <TableCell className=\"font-black text-sm tracking-widest\">{member.aam_id}</TableCell>\n                  <TableCell>\n                    <Badge className=\"bg-white text-black border-2 border-black rounded-none font-black uppercase tracking-widest text-[9px] px-4 py-1.5 group-hover:bg-black group-hover:text-white transition-all\">\n                      {member.category}\n                    </Badge>\n                  </TableCell>\n                  <TableCell className=\"hidden lg:table-cell\">\n                    <span className=\"text-[10px] font-black uppercase tracking-widest text-mono-500\">\n                      {member.firm_name || \"INDEPENDENT CONTRACTOR\"}\n                    </span>\n                  </TableCell>\n                  <TableCell className=\"text-right pr-10\">\n                    <div className=\"inline-flex items-center gap-3 bg-mono-100 border-2 border-black px-4 py-2 text-[10px] font-black uppercase tracking-widest\">\n                      <ShieldCheck className=\"h-4 w-4\" />\n                      VERIFIED\n                    </div>\n                  </TableCell>\n                </TableRow>\n              ))\n            )}\n          </TableBody>\n        </Table>\n      </div>\n\n      {/* Footer Info */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-12\">\n        <div className=\"p-10 border-4 border-black bg-black text-white space-y-6\