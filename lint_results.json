   <div className=\"space-y-3\">\n                <Label htmlFor=\"description\" className=\"text-[10px] font-black uppercase tracking-widest\">TECHNICAL DESCRIPTION</Label>\n                <Textarea \n                  id=\"description\" \n                  placeholder=\"PROVIDE SUBSTANTIVE DETAILS FOR THE EVENT REGISTRY...\" \n                  className=\"border-2 border-black rounded-none p-6 font-bold uppercase tracking-widest text-xs focus-visible:ring-0 min-h-[160px]\"\n                  value={formData.description}\n                  onChange={(e) => setFormData({...formData, description: e.target.value})}\n                  required\n                />\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"location\" className=\"text-[10px] font-black uppercase tracking-widest\">VENUE COORDINATES</Label>\n                <div className=\"relative\">\n                  <MapPin className=\"absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-black\" />\n                  <Input \n                    id=\"location\" \n                    placeholder=\"E.G. MNU AUDITORIUM / ZOOM NODE\" \n                    className=\"pl-14 border-2 border-black rounded-none h-14 font-bold uppercase tracking-widest text-xs focus-visible:ring-0\"\n                    value={formData.location}\n                    onChange={(e) => setFormData({...formData, location: e.target.value})}\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-10\">\n                <div className=\"space-y-3\">\n                  <Label htmlFor=\"start_at\" className=\"text-[10px] font-black uppercase tracking-widest\">COMMENCEMENT TIMESTAMP</Label>\n                  <Input \n                    id=\"start_at\" \n                    type=\"datetime-local\"\n                    className=\"border-2 border-black rounded-none h-14 px-6 font-black uppercase tracking-widest text-[10px] focus-visible:ring-0\"\n                    value={formData.start_at}\n                    onChange={(e) => setFormData({...formData, start_at: e.target.value})}\n                    required\n                  />\n                </div>\n                <div className=\"space-y-3\">\n                  <Label htmlFor=\"end_at\" className=\"text-[10px] font-black uppercase tracking-widest\">CONCLUSION TIMESTAMP (OPTIONAL)</Label>\n                  <Input \n                    id=\"end_at\" \n                    type=\"datetime-local\"\n                    className=\"border-2 border-black rounded-none h-14 px-6 font-black uppercase tracking-widest text-[10px] focus-visible:ring-0\"\n                    value={formData.end_at}\n                    onChange={(e) => setFormData({...formData, end_at: e.target.value})}\n                  />\n                </div>\n              </div>\n            </CardContent>\n            <CardFooter className=\"bg-black text-white p-10 flex justify-between items-center\">\n              <div className=\"flex items-center gap-4\">\n                <Clock className=\"h-8 w-8 text-white\" />\n                <div className=\"space-y-1\">\n                  <p className=\"text-[10px] font-black uppercase tracking-widest\">SYNCHRONIZED DISPATCH</p>\n                  <p className=\"text-[8px] font-bold uppercase tracking-widest text-mono-400\">GMT+5 MALDIVES STANDARD TIME.</p>\n                </div>\n              </div>\n              <Button \n                type=\"submit\" \n                disabled={loading || !formData.title || !formData.start_at}\n                className=\"h-16 px-10 bg-white text-black hover:bg-mono-200 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-white transition-all\"\n              >\n                {loading ? <Loader2 className=\"h-5 w-5 animate-spin\" /> : \"SCHEDULE INDUCTION\"}\n              </Button>\n            </CardFooter>\n          </Card>\n        </div>\n\n        <div className=\"space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none bg-white\">\n            <CardHeader className=\"border-b-2 border-black p-8\">\n              <CardTitle className=\"text-[10px] font-black uppercase tracking-[0.4em]\">VISIBILITY STATUS</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-8 space-y-6\">\n              <div className=\"flex items-center gap-4 p-6 bg-mono-50 border-2 border-black/5\">\n                <input \n                  type=\"checkbox\" \n                  id=\"published\" \n                  checked={formData.is_published}\n                  onChange={(e) => setFormData({...formData, is_published: e.target.checked})}\n                  className=\"h-5 w-5 text-black border-2 border-black rounded-none focus:ring-0\"\n                />\n                <Label htmlFor=\"published\" className=\"text-[10px] font-black uppercase tracking-widest cursor-pointer\">\n                  BROADCAST TO PUBLIC HUB\n                </Label>\n              </div>\n              <div className=\"p-6 border-2 border-black bg-white rounded-none space-y-2\">\n                <div className=\"flex items-center gap-2 text-[10px] font-black uppercase tracking-widest\">\n                  <AlertTriangle className=\"h-4 w-4\" />\n                  CONFLICT DETECTION\n                </div>\n                <p className=\"text-[8px] font-bold uppercase tracking-widest text-mono-400\">SYSTEM WILL AUDIT FOR OVERLAPPING INSTITUTIONAL EVENTS.</p>\n              </div>\n            </CardContent>\n          </Card>\n\n          <div className=\"p-8 border-4 border-black border-dashed rounded-none space-y-6 bg-mono-50\">\n            <div className=\"flex items-center gap-3\">\n              <Settings2 className=\"h-5 w-5 text-black\" />\n              <h4 className=\"text-[10px] font-black uppercase tracking-[0.4em]\">SCHEDULING NOTICE</h4>\n            </div>\n            <p className=\"text-[9px] font-black uppercase tracking-widest leading-relaxed text-mono-500\">\n              ENSURE ALL VENUE BOOKINGS ARE CONFIRMED PRIOR TO INDUCTION. MODIFICATIONS TO START TIMES WILL TRIGGER MEMBER NOTIFICATIONS.\n            </p>\n          </div>\n        </div>\n      </form>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(admin)\\admin\\content\\events\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ArrowLeft' is defined but never used.","line":27,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":27,"endColumn":12,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ArrowLeft"},"fix":{"range":[453,467],"text":""},"desc":"Remove unused variable \"ArrowLeft\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Badge' is defined but never used.","line":34,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":34,"endColumn":15,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Badge"},"fix":{"range":[570,617],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":37,"column":40,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":37,"endColumn":43,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[703,706],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[703,706],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,