eHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-16\">Date Created</TableHead>\n                  <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-16 text-right pr-10\">Actions</TableHead>\n                </TableRow>\n              </TableHeader>\n              <TableBody>\n                {loading ? (\n                  <TableRow>\n                    <TableCell colSpan={5} className=\"h-64 text-center\">\n                      <div className=\"flex flex-col items-center justify-center gap-6\">\n                        <Loader2 className=\"h-10 w-10 animate-spin text-black\" />\n                        <span className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">SYNCHRONIZING ENTRIES...</span>\n                      </div>\n                    </TableCell>\n                  </TableRow>\n                ) : posts.length === 0 ? (\n                  <TableRow>\n                    <TableCell colSpan={5} className=\"h-64 text-center\">\n                      <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">DATABASE EMPTY. NO ENTRIES DETECTED.</p>\n                    </TableCell>\n                  </TableRow>\n                ) : (\n                  posts.map((post) => (\n                    <TableRow key={post.id} className=\"border-b-2 border-black/5 last:border-none hover:bg-mono-50 transition-colors\">\n                      <TableCell className=\"pl-10 py-8\">\n                        {post.published_at ? (\n                          <div className=\"flex items-center gap-2 text-black font-black uppercase text-[10px] tracking-widest\">\n                            <CheckCircle2 className=\"h-4 w-4\" />\n                            LIVE\n                          </div>\n                        ) : (\n                          <div className=\"flex items-center gap-2 text-mono-400 font-black uppercase text-[10px] tracking-widest\">\n       