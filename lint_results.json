om \"next/link\";\n\nexport default async function JobsPage() {\n  const supabase = await createClient();\n  const { data: jobs } = await supabase\n    .from(\"job_listings\")\n    .select(\"*\")\n    .eq(\"is_active\", true)\n    .order(\"created_at\", { ascending: false });\n\n  return (\n    <div className=\"container py-24 space-y-24\">\n      <div className=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-12 border-b-8 border-black pb-12\">\n        <PageHeader \n          title=\"Career Center\"\n          description=\"Institutional repository of professional opportunities within the architectural sector.\"\n        />\n        <div className=\"bg-black px-8 py-4 border-2 border-black flex items-center gap-4\">\n          <Briefcase className=\"h-5 w-5 text-white\" />\n          <span className=\"text-[10px] font-black uppercase tracking-[0.2em] text-white\">\n            ACTIVE VACANCIES: {jobs?.length || 0} POSITIONS\n          </span>\n        </div>\n      </div>\n\n      <div className=\"space-y-12\">\n        {jobs?.map((job) => (\n          <Card key={job.id} className=\"group border-4 border-black rounded-none shadow-[12px_12px_0px_0px_rgba(0,0,0,0.1)] hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all bg-white overflow-hidden\">\n            <div className=\"flex flex-col md:flex-row\">\n              <div className=\"p-10 flex-grow space-y-8\">\n                <div className=\"flex flex-wrap items-center gap-6\">\n                  <Badge className=\"bg-black text-white rounded-none px-4 py-1 text-[10px] font-black uppercase tracking-widest border-none\">\n                    FULL-TIME\n                  </Badge>\n                  <span className=\"text-[10px] font-black text-mono-400 uppercase tracking-widest flex items-center gap-2\">\n                    <Calendar className=\"h-4 w-4\" />\n                    POSTED // {new Date(job.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}\n                  </span>\n                </div>\n                \n                <div className=\"space-y-4\">\n                  <CardTitle className=\"text-4xl font-black uppercase tracking-tighter leading-none group-hover:underline underline-offset-8 decoration-8\">\n                    {job.title}\n                  </CardTitle>\n                  <div className=\"flex items-center gap-3 text-black font-black uppercase tracking-widest text-xs\">\n                    <Building2 className=\"h-5 w-5\" />\n                    <span>{job.company}</span>\n                  </div>\n                </div>\n\n                <p className=\"text-mono-600 font-bold uppercase text-xs leading-relaxed max-w-4xl line-clamp-2\">\n                  {job.description}\n                </p>\n              </div>\n\n              <div className=\"bg-mono-50 md:w-80 p-10 flex flex-col justify-between items-center md:items-end border-t-4 md:border-t-0 md:border-l-4 border-black\">\n                <div className=\"text-center md:text-right space-y-2 mb-10 md:mb-0\">\n                  <p className=\"text-[10px] uppercase tracking-[0.3em] font-black text-mono-400\">SUBMISSION DEADLINE</p>\n                  <p className=\"text-xl font-black uppercase tracking-tighter text-black\">\n                    {job.deadline ? new Date(job.deadline).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : \"OPEN\"}\n                  </p>\n                </div>\n                <Button asChild className=\"w-full h-16 bg-black text-white hover:bg-white hover:text-black border-2 border-black font-black uppercase tracking-widest text-[10px] rounded-none transition-all group\">\n                  <Link href={`/jobs/${job.id}`} className=\"flex items-center justify-center gap-3\">\n                    VIEW POSITION DETAILS\n                    <ArrowRight className=\"h-4 w-4 group-hover:translate-x-2 transition-transform\" />\n                  </Link>\n                </Button>\n              </div>\n            </div>\n          </Card>\n        ))}\n\n        {(!jobs || jobs.length === 0) && (\n          <div className=\"py-24 text-center border-4 border-dashed border-black rounded-none space-y-6 bg-mono-50\">\n            <Briefcase className=\"h-12 w-12 text-black mx-auto opacity-20\" />\n            <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">NO ACTIVE VACANCIES REGISTERED IN ARCHIVE.</p>\n          </div>\n        )}\n      </div>\n\n      <div className=\"bg-black text-white p-12 md:p-24 space-y-12 relative overflow-hidden border-4 border-black shadow-[16px_16px_0px_0px_rgba(0,0,0,0.1)]\">\n        <div className=\"absolute top-0 right-0 w-full h-full opacity-5 bg-[repeating-linear-gradient(45deg,#ffffff,#ffffff_1px,transparent_1px,transparent_20px)]\" />\n        <div className=\"flex flex-col lg:flex-row items-center justify-between gap-16 relative z-10\">\n          <div className=\"space-y-6 max-w-2xl\">\n            <h3 className=\"text-4xl md:text-6xl font-black uppercase tracking-tighter leading-none\">Recruitment <br /> Protocol</h3>\n            <p className=\"text-lg text-mono-400 font-bold uppercase tracking-tight leading-snug\">\n              Are you seeking architectural excellence? Leverage the institutional platform to identify \n              qualified professionals for your practice.\n            </p>\n          </div>\n          <Button size=\"lg\" className=\"bg-white text-black hover:bg-mono-200 font-black uppercase tracking-widest px-16 py-10 h-auto text-[10px] border-2 border-white rounded-none shrink-0 transition-all\">\n            INITIATE VACANCY LISTING\n          </Button>\n        </div>\n      </div>\n    </div>\n  );\n}\n\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\login\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,