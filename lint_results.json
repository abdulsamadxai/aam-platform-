const [slug, setSlug] = useState(\"\");\n  const [category, setCategory] = useState(\"INSTITUTIONAL\");\n  const [body, setBody] = useState(\"**WRITE YOUR DISPATCH HERE...**\");\n  \n  const supabase = createClient();\n  const router = useRouter();\n\n  const handleTitleChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const val = e.target.value;\n    setTitle(val);\n    setSlug(val.toLowerCase().replace(/ /g, '-').replace(/[^\\w-]+/g, ''));\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setLoading(true);\n\n    const { data: { user } } = await supabase.auth.getUser();\n\n    const { error } = await supabase\n      .from(\"news_posts\")\n      .insert([\n        {\n          title,\n          slug,\n          category,\n          body,\n          author_id: user?.id,\n          published_at: new Date().toISOString() // Auto-publish for now\n        }\n      ]);\n\n    if (error) {\n      alert(\"Error creating post: \" + error.message);\n    } else {\n      setSuccess(true);\n    }\n    setLoading(false);\n  };\n\n  if (success) {\n    return (\n      <div className=\"container py-24 flex items-center justify-center\">\n        <Card className=\"max-w-xl w-full text-center p-16 space-y-10 border-4 border-black bg-black text-white rounded-none shadow-[16px_16px_0px_0px_rgba(0,0,0,0.1)]\">\n          <div className=\"h-24 w-24 bg-white flex items-center justify-center mx-auto text-black border-4 border-white\">\n            <CheckCircle2 className=\"h-12 w-12\" />\n          </div>\n          <div className=\"space-y-4\">\n            <CardTitle className=\"text-4xl font-black uppercase tracking-tighter\">DISPATCH LIVE</CardTitle>\n            <CardDescription className=\"text-sm font-black uppercase tracking-widest text-mono-400\">\n              NEWS ENTRY HAS BEEN SYNCHRONIZED TO ALL GLOBAL PUBLIC NODES.\n            </CardDescription>\n          </div>\n          <Button asChild className=\"h-16 w-full bg-white text-black hover:bg-mono-200 font-black uppercase tracking-widest text-[10px] rounded-none border-2 border-white transition-all\">\n            <Link href=\"/admin/content/news\">RETURN TO CONTROLLER</Link>\n          </Button>\n        </Card>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"container py-24 max-w-6xl space-y-24\">\n      <Button variant=\"ghost\" className=\"text-black font-black uppercase tracking-widest text-[10px] p-0 hover:bg-transparent group\" asChild>\n        <Link href=\"/admin/content/news\" className=\"flex items-center\">\n          <ArrowLeft className=\"mr-3 h-5 w-5 group-hover:-translate-x-2 transition-transform\" />\n          RETURN TO NEWS CONTROLLER\n        </Link>\n      </Button>\n\n      <div className=\"space-y-4 border-l-8 border-black pl-8\">\n        <h1 className=\"text-5xl md:text-8xl font-black uppercase tracking-tighter leading-none\">News <br /> Induction</h1>\n        <p className=\"text-sm font-black uppercase tracking-[0.4em] text-mono-400\">Public Intelligence Dispatch Protocol</p>\n      </div>\n\n      <form onSubmit={handleSubmit} className=\"grid grid-cols-1 lg:grid-cols-4 gap-16\">\n        <div className=\"lg:col-span-3 space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none overflow-hidden bg-white\">\n            <CardHeader className=\"p-10 border-b-2 border-black bg-mono-50\">\n              <CardTitle className=\"text-xs font-black uppercase tracking-[0.4em]\">EDITORIAL PARAMETERS</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-10 space-y-10\">\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"title\" className=\"text-[10px] font-black uppercase tracking-widest\">PUBLICATION TITLE</Label>\n                <Input \n                  id=\"title\" \n                  placeholder=\"E.G. OFFICIAL STATEMENT ON URBAN DEVELOPMENT...\" \n                  className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-sm focus-visible:ring-0\"\n                  value={title}\n                  onChange={handleTitleChange}\n                  required\n                />\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-10\">\n                <div className=\"space-y-3\">\n                  <Label htmlFor=\"slug\" className=\"text-[10px] font-black uppercase tracking-widest\">URI SLUG (AUTO-GENERATED)</Label>\n                  <Input \n                    id=\"slug\" \n                    placeholder=\"official-statement-...\" \n                    className=\"border-2 border-black rounded-none h-14 px-6 font-bold text-xs focus-visible:ring-0 bg-mono-50\"\n                    value={slug}\n                    onChange={(e) => setSlug(e.target.value)}\n                    required\n                  />\n                </div>\n                <div className=\"space-y-3\">\n                  <Label htmlFor=\"category\" className=\"text-[10px] font-black uppercase tracking-widest\">CLASSIFICATION</Label>\n                  <Input \n                    id=\"category\" \n                    placeholder=\"E.G. ANNOUNCEMENT\" \n                    className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-xs focus-visible:ring-0\"\n                    value={category}\n                    onChange={(e) => setCategory(e.target.value)}\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label className=\"text-[10px] font-black uppercase tracking-widest\">SUBSTANTIVE BODY (MARKDOWN)</Label>\n                <div className=\"border-2 border-black rounded-none overflow-hidden\" data-color-mode=\"light\">\n                  <MDEditor\n                    value={body}\n                    onChange={(v) => setBody(v || \"\")}\n                    preview=