\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\components\\ui\\textarea.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\emails\\BroadcastEmail.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\eslint.config.mjs","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\lib\\actions\\members.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'member' is assigned a value but never used.","line":33,"column":17,"nodeType":"Identifier","messageId":"unusedVar","endLine":33,"endColumn":23}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use server\";\n\nimport { createServiceClient } from \"@/lib/supabase/server\";\nimport { revalidatePath } from \"next/cache\";\n\n/**\n * Member Induction Action\n * BUG-033/034/043 FIX: Implemented the server-side logic for approving member registrations.\n * This creates a member record and updates the application status.\n */\nexport async function approveApplication(applicationId: string) {\n  const supabase = await createServiceClient();\n\n  // 1. Fetch application details\n  const { data: app, error: fetchError } = await supabase\n    .from(\"registration_applications\")\n    .select(\"*\")\n    .eq(\"id\", applicationId)\n    .single();\n\n  if (fetchError || !app) {\n    return { error: \"APPLICATION_NOT_FOUND\" };\n  }\n\n  // 2. Generate AAM ID (Simplified: AAM-YYYY-XXXX)\n  const year = new Date().getFullYear();\n  const { count } = await supabase.from(\"members\").select(\"*\", { count: \"exact\", head: true });\n  const aamId = `AAM-${year}-${String((count || 0) + 1).padStart(4, '0')}`;\n\n  // 3. Create Member Record\n  // NOTE: In a real flow, we would use supabase.auth.admin.createUser() here,\n  // but for now we create the member profile and invite them.\n  const { data: member, error: memberError } = await supabase\n    .from(\"members\")\n    .insert({\n      full_name: app.applicant_name,\n      email: app.email,\n      category: app.category_applied,\n      status: 'active',\n      aam_id: aamId,\n      joined_at: new Date().toISOString()\n    })\n    .select()\n    .single();\n\n  if (memberError) {\n    console.error(\"Member creation error:\", memberError);\n    return { error: \"MEMBER_CREATION_FAILED\" };\n  }\n\n  // 4. Update Application Status\n  await supabase\n    .from(\"registration_applications\")\n    .update({ status: 'approved' })\n    .eq(\"id\", applicationId);\n\n  revalidatePath(\"/admin/members\");\n  return { success: true, aamId };\n}\n\nexport async function rejectApplication(applicationId: string) {\n  const supabase = await createServiceClient();\n  \n  const { error } = await supabase\n    .from(\"registration_applications\")\n    .update({ status: 'rejected' })\n    .eq(\"id\", applicationId);\n\n  if (error) return { error: \"REJECTION_FAILED\" };\n\n  revalidatePath(\"/admin/members\");\n  return { success: true };\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\lib\\auth.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\lib\\env.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warni