text-white\">\n          <div className=\"h-12 w-12 rounded-full bg-aam-teal-500 flex items-center justify-center text-aam-navy-900 mb-6\">\n            <GraduationCap className=\"h-6 w-6\" />\n          </div>\n          <h3 className=\"font-bold text-xl mb-2\">Track Progress</h3>\n          <p className=\"text-sm text-slate-400 leading-relaxed\">\n            Log in to your member dashboard to record your activities and download \n            your annual CPD certificate.\n          </p>\n        </Card>\n      </div>\n\n      <div className=\"space-y-8\">\n        <h2 className=\"font-display text-3xl font-bold text-aam-navy-900\">How it Works</h2>\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-12\">\n          <div className=\"space-y-6\">\n            <div className=\"flex gap-4\">\n              <div className=\"h-10 w-10 rounded-full bg-aam-teal-100 flex items-center justify-center text-aam-teal-600 font-bold shrink-0\">1</div>\n              <div className=\"space-y-2\">\n                <h4 className=\"font-bold text-lg\">Participate in Activities</h4>\n                <p className=\"text-muted-foreground text-sm leading-relaxed\">\n                  Attend AAM-certified seminars, workshops, or national/international \n                  architectural conferences. Each activity is assigned a point value.\n                </p>\n              </div>\n            </div>\n            <div className=\"flex gap-4\">\n              <div className=\"h-10 w-10 rounded-full bg-aam-teal-100 flex items-center justify-center text-aam-teal-600 font-bold shrink-0\">2</div>\n              <div className=\"space-y-2\">\n                <h4 className=\"font-bold text-lg\">Record Your Hours</h4>\n                <p className=\"text-muted-foreground text-sm leading-relaxed\">\n                  Keep records of your attendance, certificates, and evidence of \n                  learning. Upload these to your member dashboard for verification.\n                </p>\n              </div>\n            </div>\n            <div className=\"flex gap-4\">\n              <div className=\"h-10 w-10 rounded-full bg-aam-teal-100 flex items-center justify-center text-aam-teal-600 font-bold shrink-0\">3</div>\n              <div className=\"space-y-2\">\n                <h4 className=\"font-bold text-lg\">Verification & Renewal</h4>\n                <p className=\"text-muted-foreground text-sm leading-relaxed\">\n                  The CPD Committee reviews submissions periodically. Once you reach \n                  the 20-point threshold, your eligibility for renewal is confirmed.\n                </p>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"bg-muted/30 p-8 md:p-12 rounded-3xl border space-y-8\">\n            <h3 className=\"font-bold text-xl text-center\">Typical CPD Journey</h3>\n            <div className=\"space-y-6\">\n              <div className=\"space-y-2\">\n                <div className=\"flex justify-between text-xs font-bold uppercase tracking-wider\">\n                  <span>Core Modules</span>\n                  <span className=\"text-aam-teal-600\">8 / 10 Points</span>\n                </div>\n                <div className=\"h-2 w-full bg-slate-200 rounded-full overflow-hidden\">\n                  <div className=\"h-full bg-aam-teal-600 w-[80%]\" />\n                </div>\n              </div>\n              <div className=\"space-y-2\">\n                <div className=\"flex justify-between text-xs font-bold uppercase tracking-wider\">\n                  <span>Elective Training</span>\n                  <span className=\"text-aam-teal-600\">4 / 5 Points</span>\n                </div>\n                <div className=\"h-2 w-full bg-slate-200 rounded-full overflow-hidden\">\n                  <div className=\"h-full bg-aam-teal-600 w-[80%]\" />\n                </div>\n              </div>\n              <div className=\"space-y-2\">\n                <div className=\"fl