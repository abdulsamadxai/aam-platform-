varName":"Clock"},"fix":{"range":[102,112],"text":""},"desc":"Remove unused variable \"Clock\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ChevronRight' is defined but never used.","line":4,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":30,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ChevronRight"},"fix":{"range":[120,134],"text":""},"desc":"Remove unused variable \"ChevronRight\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'cn' is defined but never used.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"cn"},"fix":{"range":[203,237],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createClient } from \"@/lib/supabase/server\";\nimport { \n  ArrowRight, Calendar as CalendarIcon, \n  Clock, MapPin, ChevronRight, ArrowUpRight \n} from \"lucide-react\";\nimport Link from \"next/link\";\nimport { cn } from \"@/lib/utils\";\n\nexport default async function NewsEventsPage() {\n  const supabase = await createClient();\n  \n  const { data: news } = await supabase\n    .from(\"news_posts\")\n    .select(\"*\")\n    .order(\"published_at\", { ascending: false })\n    .limit(5);\n\n  const { data: events } = await supabase\n    .from(\"events\")\n    .select(\"*\")\n    .eq(\"is_published\", true)\n    .gte(\"start_at\", new Date().toISOString())\n    .order(\"start_at\", { ascending: true })\n    .limit(4);\n\n  const featured = news?.[0];\n  const others = news?.slice(1);\n\n  return (\n    <div className=\"pt-24 min-h-screen bg-mcatp-white selection:bg-mcatp-gold selection:text-mcatp-black\">\n      {/* Page Header Band */}\n      <section className=\"bg-mcatp-black py-32\">\n        <div className=\"container\">\n          <div className=\"space-y-4\">\n            <nav className=\"flex items-center gap-2 text-[10px] font-sans font-medium uppercase tracking-[0.2em] text-mcatp-platinum\">\n              <Link href=\"/\" className=\"hover:text-mcatp-gold transition-colors\">Home</Link>\n              <span>ΓÇ║</span>\n              <span className=\"text-mcatp-white\">Bulletins & Calendar</span>\n            </nav>\n            <h1 className=\"text-5xl md:text-7xl font-display font-bold italic text-mcatp-white tracking-tight\">\n              News & Events\n            </h1>\n          </div>\n        </div>\n      </section>\n\n      <div className=\"container py-24\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-24\">\n          {/* Editorial News Feed */}\n          <div className=\"lg:col-span-8 space-y-24\">\n            \n            {/* Featured Article */}\n            {featured && (\n              <article className=\"group grid grid-cols-1 md:grid-cols-3 gap-0 border border-mcatp-black/10 overflow-hidden\">\n                <div className=\"md:col-span-2 aspect-[4/3] md:aspect-auto relative overflow-hidden bg-mcatp-black\">\n                  <div className=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1487958449943-2429e8be8625?q=80&w=2070')] bg-cover bg-center grayscale opacity-60 group-hover:scale-105 transition-transform duration-1000\" />\n                  <div className=\"absolute top-8 left-8\">\n                    <span className=\"bg-mcatp-gold text-mcatp-black px-4 py-1 text-[10px] font-sans font-medium uppercase tracking-widest\">\n                      Featured Report\n                    </span>\n                  </div>\n                </div>\n                <div className=\"p-12 flex flex-col justify-between space-y-8 bg-mcatp-white\">\n                  <div className=\"space-y-6\">\n                    <span className=\"font-mono text-[11px] text-mcatp-gold uppercase tracking-widest\">\n                      {new Date(featured.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}\n                    </span>\n                    <h2 className=\"text-3xl font-display font-bold tracking-tight leading-tight group-hover:text-mcatp-gold transition-colors\">\n                      {featured.title}\n                    </h2>\n                    <p className=\"font-serif text-sm text-mcatp-black/60 leading-relaxed line-clamp-4\">\n                      {featured.body}\n                    </p>\n                  </div>\n                  <Link href={`/news/${featured.slug}`} className=\"inline-flex items-center gap-4 text-[11px] font-sans font-medium uppercase tracking-[0.3em] border-b border-mcatp-black pb-2 w-fit\">\n                    Read Report <ArrowUpRight className=\"h-4 w-4\" />\n                  </Link>\n                </div>\n              </article>\n            )}\n\n            {/* Subsequent Articles List */}\n            <div className=\"space-y-12\">\n              <h3 className=\"text-[11px] font-sans font-medium uppercase tracking-[0.5em] text-mcatp-gold border-b border-mcatp-black/10 pb-4\">Recent Bulletins</h3>\n              <div className=\"space-y-0\">\n                {others?.map((post) => (\n                  <Link \n                    key={post.id} \n                    href={`/news/${post.slug}`}\n                    className=\"group flex flex-col md:flex-row gap-12 py-10 border-b border-mcatp-black/10 hover:bg-mcatp-surface transition-all px-4\"\n                  >\n                    <div className=\"w-full md:w-48 aspect-video bg-mcatp-surface overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700\">\n                      <div className=\"w-full h-full bg-[url('https://images.unsplash.com/photo-1511818330061-2031993382ff?q=80&w=2070')] bg-cover bg-center\" />\n                    </div>\n                    <div className=\"flex-1 space-y-4\">\n                      <div className=\"flex items-center gap-4\">\n                        <span className=\"font-mono text-[10px] text-mcatp-platinum uppercase\">\n                          {new Date(post.published_at).toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: '2-digit' })}\n                        </span>\n                        <span className=\"h-[1px] w-8 bg-mcatp-gold/30\" />\n                        <span className=\"text-[10px] font-sans font-medium uppercase tracking-widest text-mcatp-black/40\">\n                          {post.category || \"Official Notice\"}\n                        </span>\n                      </div>\n                      <h4 className=\"text-xl font-display font-bold tracking-tight group-hover:translate-x-2 transition-transform duration-500\">\n                        {post.title}\n                      </h4>\n                    </div>\n                    <div className=\"hidden md:flex items-center\">\n                      <ArrowRight className=\"h-5 w-5 text-mcatp-black/10 group-hover:text-mcatp-gold group-hover:translate-x-2 transition-all\" />\n                    </div>\n                  </Link>\n                ))}\n              </div>\n            </div>\n          </div>\n\n          {/* Sidebar / Calendar */}\n          <div className=\"lg:col-span-4 space-y-24\">\n            <section className=\"bg-mcatp-white border border-mcatp-black/10 shadow-2xl overflow-hidden\">\n              <div className=\"bg-mcatp-black p-8 flex justify-between items-center\">\n                <h3 className=\"text-[11px] font-sans font-medium uppercase tracking-[0.3em] text-mcatp-white\">Events Calendar</h3>\n                <Link href=\"/events\" className=\"text-[9px] font-sans font-medium uppercase tracking-widest text-mcatp-gold\">View Full</Link>\n              </div>\n              <div className=\"p-8 space-y-8\">\n                {events?.map((event) => (\n                  <div key={event.id} className=\"group flex gap-8 pb-8 border-b border-mcatp-black/5 last:border-0 last:pb-0 cursor-pointer\">\n                    <div className=\"flex flex-col items-center justify-center h-16 w-16 bg-mcatp-surface shrink-0 group-hover:bg-mcatp-gold transition-colors\">\n                      <span className=\"text-[9px] uppercase font-sans font-medium tracking-widest mb-1 text-mcatp-black/40 group-hover:text-mcatp-black/60\">\n                        {new Date(event.start_at).toLocaleDateString('en-US', { month: 'short' })}\n                      </span>\n                      <span className=\"text-2xl font-display font-bold leading-none tracking-tighter\">\n                        {new Date(event.start_at).getDate()}\n                      </span>\n                    </div>\n                    <div className=\"space-y-2 py-1\">\n                      <h4 className=\"font-display font-bold text-lg tracking-tight leading-tight group-hover:text-mcatp-gold transition-colors\">\n                        {event.title}\n                      </h4>\n                      <div className=\"flex flex-col gap-1 text-[10px] font-sans font-medium uppercase tracking-widest text-mcatp-black/40\">\n                        <div className=\"flex items-center gap-2\">\n                          <MapPin className=\"h-3 w-3 text-mcatp-gold\" />\n                          <span className=\"line-clamp-1\">{event.location}</span>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                ))}\n\n                {(!events || events.length === 0) && (\n                  <div className=\"py-12 text-center text-mcatp-platinum font-sans font-medium uppercase tracking-widest text-[10px] border border-mcatp-black/5 border-dashed\">\n                    No Scheduled Entries.\n                  </div>\n                )}\n              </div>\n            </section>\n\n            {/* Official Notice Board */}\n            <section classN