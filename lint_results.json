 </TableHeader>\n          <TableBody>\n            {agmRecords.map((record) => (\n              <TableRow key={record.year} className=\"border-b border-black/10 hover:bg-mono-50 transition-colors\">\n                <TableCell className=\"font-black text-black px-8 py-8 text-xl tracking-tighter\">{record.year}</TableCell>\n                <TableCell className=\"font-bold uppercase tracking-tight text-sm\">{record.title}</TableCell>\n                <TableCell className=\"text-[10px] font-black uppercase tracking-widest text-mono-400\">{record.date}</TableCell>\n                <TableCell>\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"bg-black text-white font-black px-3 py-1 text-[9px] uppercase tracking-widest\">\n                      {record.resolutions} RESOLUTIONS PASSED\n                    </span>\n                  </div>\n                </TableCell>\n                <TableCell className=\"text-right px-8\">\n                  <button className=\"inline-flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] border-b-2 border-black pb-1 hover:text-mono-600 transition-colors group\">\n                    <Download className=\"h-4 w-4\" />\n                    DOWNLOAD REPORT\n                  </button>\n                </TableCell>\n              </TableRow>\n            ))}\n          </TableBody>\n        </Table>\n      </div>\n\n      <div className=\"flex flex-col lg:flex-row gap-12 items-center bg-black p-12 md:p-24 text-white relative overflow-hidden\">\n        <div className=\"absolute inset-0 opacity-10 bg-[radial-gradient(#ffffff_1px,transparent_1px)] bg-[size:20px_20px]\" />\n        <div className=\"h-24 w-24 bg-white flex items-center justify-center shrink-0 relative z-10\">\n          <FileText className=\"h-10 w-10 text-black\" />\n        </div>\n        <div className=\"space-y-4 relative z-10 flex-grow\">\n          <h3 className=\"text-3xl md:text-5xl font-black uppercase tracking-tighter leading-none\">AAM <br /> Constitution</h3>\n          <p className=\"text-mono-400 text-lg font-medium leading-tight max-w-xl\">\n            For historical records prior to 2023 or specific queries regarding past \n            general meetings, please contact the AAM Secretariat.\n          </p>\n        </div>\n        <button className=\"bg-white text-black font-black uppercase tracking-widest text-xs py-6 px-12 border-2 border-white hover:bg-black hover:text-white transition-all relative z-10 group\">\n          REQUEST ARCHIVES <ArrowRight className=\"inline-block ml-3 h-4 w-4 group-hover:translate-x-2 transition-transform\" />\n        </button>\n      </div>\n    </div>\n  );\n}\n\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\about\\committee\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'supabase' is assigned a value but never used.","line":6,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":17},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":33,"column":19,"nodeType":"JSXOpeningElement","endLine":33,"endColumn":168}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { PageHeader } from \"@/components/shared/PageHeader\";\nimport { Card, CardContent } from \"@/components/ui/card\";\nimport { createClient } from \"@/lib/supabase/server\";\n\nexport default async function CommitteePage() {\n  const supabase = await createClient();\n  \n  // In a real app, we'd fetch from committee_members table\n  const committee = [\n    { name: \"Ahmed Ibrahim\", role: \"President\", photo: null },\n    { name: \"Mariyam Zeena\", role: \"Vice President\", photo: null },\n    { name: \"Mohamed Rishwan\", role: \"General Secretary\", photo: null },\n    { name: \"Aishath Hana\", role: \"Treasurer\", photo: null },\n  ];\n\n  return (\n    <div className=\"container py-24 space-y-24\">\n      <PageHeader \n        title=\"EXECUTIVE COMMITTEE\"\n        description=\"The institutional leadership team governing the Architects Association Maldives.\"\n      />\n\n      <section className=\"space-y-12\">\n        <h2 className=\"text-3xl font-black uppercase tracking-tighter border-b-8 border-black pb-6\">\n          Incumbent Committee (2025-2026)\n        </h2>\n        \n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12\">\n          {committee.map((member) => (\n            <Card key={member.name} className=\"border-2 border-black rounded-none shadow-none group bg-white hover:bg-mono-50 transition-all overflow-hidden\">\n              <div className=\"aspect-[4/5] bg-black relative overflow-hidden border-b-2 border-black\">\n                {member.photo ? (\n                  <img src={member.photo} alt={member.name} className=\"object-cover h-full w-full grayscale group-hover:scale-105 transition-transform duration-700\" />\n                ) : (\n                  <div className=\"flex items-center justify-center h-full text-white bg-black\">\n                    <span className=\"text-6xl font-black\">{member.name.charAt(0)}</span>\n                  </div>\n                )}\n              </div>\n              <CardContent className=\"p-8 text-center space-y-2\">\n                <h3 className=\"font-black text-xl uppercase tracking-tighter leading-tight\">{member.name}</h3>\n                <p className=\"text-[10px] font-bold text-mono-500 uppercase tracking-[0.3em]\">\n                  {member.role}\n                </p>\n              </CardContent>\n            </Card>\n          ))}\n        </div>\n      </section>\n\n      <section className=\"bg-black text-white p-12 md:p-24 text-center space-y-12 relative overflow-hidden\">\n        <div className=\"absolute top-0 left-0 w-full h-full opacity-5 bg-[repeating-linear-gradient(45deg,#ffffff,#ffffff_10px,transparent_10px,transparent_20px)]\" />\n        <div className=\"relative z-10 max-w-2xl mx-auto space-y-8\">\n          <h2 className=\"text-4xl md:text-6xl font-black uppercase tracking-tighter leading-none\">Institutional <br /> Archive</h2>\n          <p className=\"text-xl text-mono-400 font-medium leading-tight\">\n            Consult the historical records of the dedicated professionals who have steered the association across previous terms.\n          </p>\n          <button className=\"text-xs font-black uppercase tracking-[0.4em] border-b-2 border-white pb-2 hover:text-mono-300 transition-colors\">\n            ACCESS COMMITTEE RECORDS\n          </button>\n        </div>\n      </section>\n    </div>\n  );\n}\n\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\about\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\about\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ArrowRight' is defined but never used.","line":1,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":20,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ArrowRight"},"fix":{"range":[9,20],"text":""},"desc":"Remove unused variable \"ArrowRight\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { ArrowRight, Quote } from \"lucide-react\";\n\nexport default function AboutPage() {\n  return (\n    <div className=\"space-y-24\">\n      {/* 01. INTRO */}\n      <article className=\"space-y-12\">\n        <h2 className=\"text-4xl font-display font-bold tracking-tight\">The Guardians of Maldivian <br /> Architectural Integrity</h2>\n        \n        <div className=\"space-y-8 text-[16px] font-serif leading-[1.8] text-mcatp-black/80\">\n          <p>\n            Established as the primary regulatory body for the built environment, the Maldives Council of Architects and Town Planners (MCATP) stands at the intersection of cultural heritage and contemporary governance. For over two decades, the Council has been the custodian of professional standards, ensuring that every structure within the archipelago meets the highest benchmarks of safety, sustainability, and aesthetic excellence.\n          </p>\n          \n          <p>\n            Our mandate extends beyond simple registration; we are the architects of the profession itself. By accrediting educational institutions and facilitating continuing professional development, we empower a new generation of Maldivian designers to shape an urban landscape that is both resilient and culturally resonant.\n          </p>\n        </div>\n      </article>\n\n      {/* 02. PULL QUOTE */}\n      <section className=\"relative py-12 border-t border-b border-mcatp-black/5\">\n        <Quote className=\"absolute -top-6 left-0 h-12 w-12 text-mcatp-gold opacity-30\" />\n        <blockquote className=\"text-2xl md:text-3xl font-display font-bold italic tracking-tight text-mcatp-black leading-relaxed\">\n          &quot;Architecture is the physical manifestation of our civilization. The Council ensures that this manifestation is one of precision, honor, and enduring quality.&quot;\n        </blockquote>\n      </section>\n\n      {/* 03. MISSION & VISION */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-16\">\n        <div className=\"space-y-8\">\n          <h3 className=\"text-2xl font-sans font-medium uppercase tracking-[0.2em] text-mcatp-gold\">Our Mission</h3>\n          <p className=\"font-serif leading-[1.8]\">\n            To regulate and promote the profession of architecture and town planning through the enforcement of rigorous ethical codes and technical standards, safeguarding the public interest and the natural beauty of the Maldives.\n          </p>\n        </div>\n        <div className=\"space-y-8\">\n          <h3 className=\"text-2xl font-sans font-medium uppercase tracking-[0.2em] text-mcatp-gold\">Our Vision</h3>\n          <p className=\"font-serif leading-[1.8]\">\n            To position the Maldives as a global beacon of sustainable island urbanism, where professional excellence and traditional craft coalesce to create a world-class built environment.\n          </p>\n        </div>\n      </div>\n\n      {/* 04. SECTION DIVIDER */}\n      <div className=\"py-12\">\n        <div className=\"h-[1px] w-full bg-mcatp-black/10\" />\n      </div>\n\n      {/* 05. CORE VALUES */}\n      <section className=\"space-y-12\">\n        <h3 className=\"text-3xl font-display font-bold italic tracking-tight\">Professional Pillars</h3>\n        <div className=\"grid grid-cols-1 gap-8\">\n          {[\n            { title: \"Statutory Authority\", desc: \"Operating under the official ordinance to provide a legal framework for professional practice.\" },\n            { title: \"Educational Excellence\", desc: \"Setting the global standard for architectural pedagogy and institutional validation.\" },\n            { title: \"Public Trust\", desc: \"Ensuring that the citizens of the Maldives are served by verified and competent professionals.\" }\n          ].map((item, i) => (\n            <div key={i} className=\"flex gap-12 group\">\n              <span className=\"font-mono text-mcatp-gold text-lg\">0{i + 1}</span>\n              <div className=\"space-y-2\">\n                <h4 className=\"font-sans font-medium uppercase tracking-widest text-mcatp-black\">{item.title}</h4>\n                <p className=\"font-serif text-mcatp-black/60\">{item.desc}</p>\n              </div>\n            </div>\n          ))}\n        </div>\n      </section>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\accreditation\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CardContent' is defined but never used.","line":8,"column":16,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":27,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CardContent"},"fix":{"range":[193,206],"text":""},"desc":"Remove unused variable \"CardContent\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { PageHeader } from \"@/components/shared/PageHeader\";\nimport { \n  Accordion, \n  AccordionContent, \n  AccordionItem, \n  AccordionTrigger \n} from \"@/components/ui/accordion\";\nimport { Card, CardContent } from \"@/components/ui/card\";\nimport { CheckCircle2, ShieldCheck, FileText, Info } from \"lucide-react\";\n\n// Need accordion component\n// npx.cmd shadcn add accordion -y\n\nexport default function AccreditationPage() {\n  return (\n    <div className=\"container py-12 space-y-16\">\n      <PageHeader \n        title=\"Accreditation & Validation\"\n        description=\"Guidelines and standards for architectural education and professional validation in the Maldives.\"\n      />\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-12\">\n        <div className=\"lg:col-span-2 space-y-12\">\n          <section className=\"space-y-6\">\n            <h2 className=\"font-display text-3xl font-bold text-aam-navy-900\">Validation of Programmes</h2>\n            <p className=\"text-muted-foreground text-lg leading-relaxed\">\n              AAM works closely with the Maldives Qualification Authority (MQA) to ensure \n              that architectural degrees and diplomas meet the rigorous standards \n              required for professional practice.\n            </p>\n            \n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4\">\n              <div className=\"flex gap-4 p-6 rounded-card border bg-card\">\n                <ShieldCheck className=\"h-8 w-8 text-aam-teal-600 shrink-0\" />\n                <div className=\"space-y-1\">\n                  <h4 className=\"font-bold\">Global Standards</h4>\n                  <p className=\"text-xs text-muted-foreground leading-relaxed\">\n                    Aligning with UIA and CAA standards for architectural education.\n                  </p>\n                </div>\n              </div>\n              <div className=\"flex gap-4 p-6 rounded-card border bg-card\">\n                <FileText className=\"h-8 w-8 text-aam-teal-600 shrink-0\" />\n                <div className=\"space-y-1\">\n                  <h4 className=\"font-bold\">Fee Structure</h4>\n                  <p className=\"text-xs text-muted-foreground leading-relaxed\">\n                    Clear and transparent fees for institutional accreditation.\n                  </p>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <section className=\"space-y-6\">\n            <h2 className=\"font-display text-3xl font-bold text-aam-navy-900\">Accredited Institutions</h2>\n            <div className=\"space-y-4\">\n              <div className=\"p-8 border-l-4 border-aam-teal-600 bg-aam-teal-50/50 rounded-r-card\">\n                <h3 className=\"font-bold text-xl mb-1\">Maldives National University (MNU)</h3>\n                <p className=\"text-sm font-medium text-aam-teal-700 mb-4 tracking-wide uppercase\">Bachelor of Arts in Architecture</p>\n                <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\n                  <CheckCircle2 className=\"h-4 w-4 text-aam-teal-600\" />\n                  <span>Validated until 2028</span>\n                </div>\n              </div>\n              <div className=\"p-8 border-l-4 border-slate-300 bg-slate-50 rounded-r-card\">\n                <h3 className=\"font-bold text-xl mb-1\">Villa College</h3>\n                <p className=\"text-sm font-medium text-muted-foreground mb-4 tracking-wide uppercase\">Foundation in Architecture</p>\n                <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\n                  <Info className=\"h-4 w-4\" />\n                  <span>Provisional Status</span>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          <section className=\"space-y-6\">\n            <h2 className=\"font-display text-3xl font-bold text-aam-navy-900\">Frequently Asked Questions</h2>\n            <Accordion type=\"single\" collapsible className=\"w-full\">\n              <AccordionItem value=\"item-1\">\n                <AccordionTrigger className=\"text-left font-bold text-aam-navy-900\">How do I verify a foreign degree?</AccordionTrigger>\n                <AccordionContent className=\"text-muted-foreground leading-relaxed\">\n                  Foreign degrees must be first evaluated by MQA. Once evaluated, AAM reviews the curriculum \n                  to ensure it matches our professional practice requirements for registration.\n                </AccordionContent>\n              </AccordionItem>\n              <AccordionItem value=\"item-2\">\n                <AccordionTrigger className=\"text-left font-bold text-aam-navy-900\">What are the requirements for institutional accreditation?</AccordionTrigger>\n                <AccordionContent className=\"text-muted-foreground leading-relaxed\">\n                  Institutions must provide a detailed syllabus, faculty profiles, studio facilities \n                  information, and samples of student work for review by the AAM Validation Board.\n                </AccordionContent>\n              </AccordionItem>\n              <AccordionItem value=\"item-3\">\n                <AccordionTrigger className=\"text-left font-bold text-aam-navy-900\">Can I practice without an accredited degree?</AccordionTrigger>\n                <AccordionContent className=\"text-muted-foreground leading-relaxed\">\n                  Registration as a Professional Member requires a degree from an accredited or validated \n                  programme. Those without such degrees may apply for other membership categories.\n                </AccordionContent>\n              </AccordionItem>\n            </Accordion>\n          </section>\n        </div>\n\n        <div className=\"space-y-8\">\n          <Card className=\"bg-aam-navy-900 text-white border-none p-8 space-y-6\">\n            <h3 className=\"font-display text-2xl font-bold\">Resources</h3>\n            <ul className=\"space-y-4\">\n              <li className=\"flex items-center gap-3 group cursor-pointer\">\n                <div className=\"h-8 w-8 rounded bg-white/10 flex items-center justify-center group-hover:bg-aam-teal-600 transition-colors\">\n                  <FileText className=\"h-4 w-4\" />\n                </div>\n                <span className=\"text-sm font-medium\">Validation Guide 2026</span>\n              </li>\n              <li className=\"flex items-center gap-3 group cursor-pointer\">\n                <div className=\"h-8 w-8 rounded bg-white/10 flex items-center justify-center group-hover:bg-aam-teal-600 transition-colors\">\n                  <FileText className=\"h-4 w-4\" />\n                </div>\n                <span className=\"text-sm font-medium\">Fee Structure PDF</span>\n              </li>\n              <li className=\"flex items-center gap-3 group cursor-pointer\">\n                <div className=\"h-8 w-8 rounded bg-white/10 flex items-center justify-center group-hover:bg-aam-teal-600 transition-colors\">\n                  <FileText className=\"h-4 w-4\" />\n                </div>\n                <span className=\"text-sm font-medium\">Application Form</span>\n              </li>\n            </ul>\n          </Card>\n\n          <div className=\"bg-aam-teal-50 p-8 rounded-card border border-aam-teal-100 space-y-4\">\n            <h4 className=\"font-bold text-aam-teal-700\">Need Assistance?</h4>\n            <p className=\"text-sm text-muted-foreground leading-relaxed\">\n              If you have specific questions regarding your qualification or \n              institutional validation, please contact our Education Committee.\n            </p>\n            <button className=\"w-full bg-aam-teal-600 text-white font-bold py-3 rounded-button hover:bg-aam-teal-700 transition-colors\">\n              Contact Committee\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\competitions\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\contact\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Button' is defined but never used.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":16,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Button"},"fix":{"range":[212,261],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Send' is defined but never used.","line":9,"column":24,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":28,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Send"},"fix":{"range":[292,298],"text":""},"desc":"Remove unused variable \"Send\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Globe' is defined but never used.","line":10,"column":17,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":22,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Globe"},"fix":{"range":[324,331],"text":""},"desc":"Remove unused variable \"Globe\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ShieldCheck' is defined but never used.","line":10,"column":24,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":35,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ShieldCheck"},"fix":{"range":[331,344],"text":""},"desc":"Remove unused variable \"ShieldCheck\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'cn' is defined but never used.","line":13,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":13,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"cn"},"fix":{"range":[411,445],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used.","line":44,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":44,"endColumn":19}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":6,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState } from \"react\";\nimport { useForm } from \"react-hook-form\";\nimport { zodResolver } from \"@hookform/resolvers/zod\";\nimport { contactSchema, ContactInput } from \"@/lib/validations\";\nimport { Button } from \"@/components/ui/button\";\nimport { \n  Mail, Phone, MapPin, Send, Loader2, \n  CheckCircle2, Globe, ShieldCheck, ArrowRight \n} from \"lucide-react\";\nimport Link from \"next/link\";\nimport { cn } from \"@/lib/utils\";\n\nexport default function ContactPage() {\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [isSuccess, setIsSuccess] = useState(false);\n\n  const {\n    register,\n    handleSubmit,\n    reset,\n    formState: { errors },\n  } = useForm<ContactInput>({\n    resolver: zodResolver(contactSchema),\n  });\n\n  const onSubmit = async (data: ContactInput) => {\n    setIsSubmitting(true);\n    try {\n      const response = await fetch(\"/api/contact\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(data),\n      });\n\n      if (response.ok) {\n        setIsSuccess(true);\n        reset();\n      } else {\n        const err = await response.json();\n        alert(\"Transmission error: \" + err.error);\n      }\n    } catch (error) {\n      alert(\"Unexpected error.\");\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  if (isSuccess) {\n    return (\n      <div className=\"pt-24 min-h-screen bg-mcatp-white flex items-center justify-center p-6\">\n        <div className=\"max-w-xl w-full bg-mcatp-black text-mcatp-white p-16 space-y-12 text-center\">\n          <div className=\"flex justify-center\">\n            <div className=\"h-20 w-20 bg-mcatp-gold flex items-center justify-center text-mcatp-black\">\n              <CheckCircle2 className=\"h-10 w-10\" />\n            </div>\n          </div>\n          <div className=\"space-y-6\">\n            <h2 className=\"text-4xl font-display font-bold italic tracking-tight\">Transmission Received</h2>\n            <p className=\"font-serif text-mcatp-platinum leading-relaxed\">\n              Your communication has been logged in the official MCATP registry. The Secretariat will review your briefing and respond within 48 business hours.\n            </p>\n          </div>\n          <button \n            onClick={() => setIsSuccess(false)}\n            className=\"w-full btn-gold !py-6\"\n          >\n            New Dispatch\n          </button>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"pt-24 min-h-screen bg-mcatp-white\">\n      {/* Page Header Band */}\n      <section className=\"bg-mcatp-black py-32\">\n        <div className=\"container\">\n          <div className=\"space-y-4\">\n            <nav className=\"flex items-center gap-2 text-[10px] font-sans font-medium uppercase tracking-[0.2em] text-mcatp-platinum\">\n              <Link href=\"/\" className=\"hover:text-mcatp-gold transition-colors\">Home</Link>\n              <span>ΓÇ║</span>\n              <span className=\"text-mcatp-white\">Secretariat Portal</span>\n            </nav>\n            <h1 className=\"text-5xl md:text-7xl font-display font-bold italic text-mcatp-white tracking-tight\">\n              Contact Us\n            </h1>\n          </div>\n        </div>\n      </section>\n\n      <div className=\"container py-24\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-0 border border-mcatp-black/10 overflow-hidden shadow-2xl\">\n          \n          {/* Left Column: Contact Details (40%) */}\n          <div className=\"lg:col-span-5 bg-mcatp-black text-mcatp-white p-16 md:p-24 space-y-20 relative\">\n            <div className=\"space-y-12\">\n              <div className=\"space-y-2\">\n                <span className=\"text-[10px] font-sans font-medium uppercase tracking-[0.5em] text-mcatp-gold\">Official Channels</span>\n                <h2 className=\"text-4xl font-display font-bold italic tracking-tight\">The Secretariat</h2>\n              </div>\n              \n              <div className=\"space-y-12\">\n                <div className=\"flex gap-8 group\">\n                  <div className=\"h-12 w-12 border border-mcatp-gold/30 flex items-center justify-center group-hover:bg-mcatp-gold group-hover:text-mcatp-black transition-all\">\n                    <Mail className=\"h-5 w-5\" />\n                  </div>\n                  <div className=\"space-y-2\">\n                    <p className=\"text-[9px] font-sans font-medium uppercase tracking-widest text-mcatp-platinum\">Email Correspondence</p>\n                    <p className=\"text-lg font-sans font-medium tracking-tight\">info@mcatp.gov.mv</p>\n                  </div>\n                </div>\n                <div className=\"flex gap-8 group\">\n                  <div className=\"h-12 w-12 border border-mcatp-gold/30 flex items-center justify-center group-hover:bg-mcatp-gold group-hover:text-mcatp-black transition-all\">\n                    <Phone className=\"h-5 w-5\" />\n                  </div>\n                  <div className=\"space-y-2\">\n                    <p className=\"text-[9px] font-sans font-medium uppercase tracking-widest text-mcatp-platinum\">Technical Line</p>\n                    <p className=\"text-lg font-sans font-medium tracking-tight\">+960 333 4455</p>\n                  </div>\n                </div>\n                <div className=\"flex gap-8 group\">\n                  <div className=\"h-12 w-12 border border-mcatp-gold/30 flex items-center justify-center group-hover:bg-mcatp-gold group-hover:text-mcatp-black transition-all\">\n                    <MapPin className=\"h-5 w-5\" />\n                  </div>\n                  <div className=\"space-y-2\">\n                    <p className=\"text-[9px] font-sans font-medium uppercase tracking-widest text-mcatp-platinum\">Physical Station</p>\n                    <p className=\"text-lg font-sans font-medium tracking-tight leading-tight uppercase\">\n                      H. Mialani, 3rd Floor,<br />\n                      Mal├⌐, Republic of Maldives\n                    </p>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            {/* B&W Styled Map Area Placeholder */}\n            <div className=\"aspect-video bg-mcatp-white/5 border border-mcatp-white/10 relative overflow-hidden group\">\n               <div className=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1544911845-1f34a3eb46b1?q=80&w=2070')] bg-cover bg-center grayscale opacity-20 group-hover:scale-105 transition-transform duration-1000\" />\n               <div className=\"absolute inset-0 flex items-center justify-center\">\n                  <span className=\"text-[9px] font-sans font-medium uppercase tracking-[0.5em] text-mcatp-white/40\">Geometric View</span>\n               </div>\n            </div>\n          </div>\n\n          {/* Right Column: Dispatch Form (60%) */}\n          <div className=\"lg:col-span-7 bg-mcatp-white p-16 md:p-24\">\n            <form onSubmit={handleSubmit(onSubmit)} className=\"space-y-12\">\n              <div className=\"space-y-2\">\n                <span className=\"text-[10px] font-sans font-medium uppercase tracking-[0.5em] text-mcatp-gold\">Inquiry Form</span>\n                <h2 className=\"text-4xl font-display font-bold tracking-tight\">Initiate Dispatch</h2>\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-12\">\n                <div className=\"space-y-4\">\n                  <label className=\"text-[11px] font-sans font-medium uppercase tracking-[0.2em] text-mcatp-black\">Full Name</label>\n                  <input \n                    {...register(\"name\")}\n                    type=\"text\" \n                    placeholder=\"ENTER IDENTITY\"\n                    className=\"w-full bg-transparent border-b border-mcatp-black/10 py-4 font-sans font-medium text-sm placeholder:text-mcatp-black/10 focus:outline-none focus:border-mcatp-gold transition-colors\"\n                  />\n                  {errors.name && <p className=\"text-[9px] font-sans font-bold text-mcatp-gold uppercase\">{errors.name.message}</p>}\n                </div>\n                <div className=\"space-y-4\">\n                  <label className=\"text-[11px] font-sans font-medium uppercase tracking-[0.2em] text-mcatp-black\">Email Address</label>\n                  <input \n                    {...register(\"email\")}\n                    type=\"email\" \n                    placeholder=\"YOU@CORRESPONDENCE.MV\"\n                    className=\"w-full bg-transparent border-b border-mcatp-black/10 py-4 font-sans font-medium text-sm placeholder:text-mcatp-black/10 focus:outline-none focus:border-mcatp-gold transition-colors\"\n                  />\n                  {errors.email && <p className=\"text-[9px] font-sans font-bold text-mcatp-gold uppercase\">{errors.email.message}</p>}\n                </div>\n              </div>\n\n              <div className=\"space-y-4\">\n                <label className=\"text-[11px] font-sans font-medium uppercase tracking-[0.2em] text-mcatp-black\">Subject Matter</label>\n                <input \n                  {...register(\"subject\")}\n                  type=\"text\" \n                  placeholder=\"E.G. REGISTRATION QUERY\"\n                  className=\"w-full bg-transparent border-b border-mcatp-black/10 py-4 font-sans font-medium text-sm placeholder:text-mcatp-black/10 focus:outline-none focus:border-mcatp-gold transition-colors\"\n                />\n                {errors.subject && <p className=\"text-[9px] font-sans font-bold text-mcatp-gold uppercase\">{errors.subject.message}</p>}\n              </div>\n\n              <div className=\"space-y-4\">\n                <label className=\"text-[11px] font-sans font-medium uppercase tracking-[0.2em] text-mcatp-black\">Detailed Briefing</label>\n                <textarea \n                  {...register(\"body\")}\n                  placeholder=\"PROVIDE FULL TECHNICAL CONTEXT...\"\n                  rows={6}\n                  className=\"w-full bg-transparent border-b border-mcatp-black/10 py-4 font-serif text-lg placeholder:text-mcatp-black/10 focus:outline-none focus:border-mcatp-gold transition-colors resize-none\"\n           