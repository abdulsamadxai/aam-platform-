nt <br /> Registry</h1>\n          <p className=\"text-sm font-black uppercase tracking-[0.4em] text-mono-400\">Institutional Calendar Management</p>\n        </div>\n        <div className=\"flex gap-4\">\n          <Button asChild className=\"h-16 px-10 bg-black text-white hover:bg-mono-800 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-black transition-all\">\n            <Link href=\"/admin/content/events/new\" className=\"flex items-center gap-3\">\n              <Plus className=\"h-4 w-4\" />\n              SCHEDULE NEW EVENT\n            </Link>\n          </Button>\n          <Button variant=\"outline\" asChild className=\"h-16 px-10 border-4 border-black text-black hover:bg-black hover:text-white rounded-none font-black uppercase tracking-widest text-[10px] transition-all\">\n            <Link href=\"/admin\">COMMAND CENTER</Link>\n          </Button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-4 gap-12\">\n        <div className=\"lg:col-span-3\">\n          <div className=\"border-[4px] border-black bg-white overflow-hidden shadow-[12px_12px_0px_0px_rgba(0,0,0,0.1)]\">\n            <Table>\n              <TableHeader>\n                <TableRow className=\"bg-black hover:bg-black border-none\">\n                  <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-16 pl-10\">Status</TableHead>\n                  <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-16\">Event Identity</TableHead>\n                  <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-16\">Timeline</TableHead>\n                  <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-16\">Venue</TableHead>\n                  <TableHead className=\"text-white font-black uppercase tracking-widest text-[10px] h-16 text-right pr-10\">Actions</TableHead>\n                </TableRow>\n              </TableHeader>\n              <TableBody>\n                {loading ? (\n                  <TableRow>\n                    <TableCell colSpan={5} className=\"h-64 text-center\">\n                      <div className=\"flex flex-col items-center justify-center gap-6\">\n                        <Loader2 className=\"h-10 w-10 animate-spin text-black\" />\n                        <span className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">ACCESSING CALENDAR NODES...</span>\n                      </div>\n                    </TableCell>\n                  </TableRow>\n                ) : events.length === 0 ? (\n                  <TableRow>\n                    <TableCell colSpan={5} className=\"h-64 text-center\">\n                      <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">CALENDAR ARCHIVE VACANT.</p>\n                    </TableCell>\n                  </TableRow>\n                ) : (\n                  events.map((event) => (\n                    <TableRow key={event.id} className=\"border-b-2 border-black/5 last:border-none hover:bg-mono-50 transition-colors\">\n                      <TableCell className=\"pl-10 py-8\">\n                        {event.is_published ? (\n                          <div className=\"flex items-center gap-2 text-black font-black uppercase text-[10px] tracking-widest\">\n                            <CheckCircle2 className=\"h-4 w-4\" />\n                            ACTIVE\n                          </div>\n                        ) : (\n                          <div className=\"flex items-center gap-2 text-mono-400 font-black uppercase text-[10px] tracking-widest\">\n                            <XCircle className=\"h-4 w-4\" />\n                            HIDDEN\n                          </div>\n                        )}\n                      </TableCell>\n                      <TableCell className=\"max-w-xs\">\n                        <p className=\"text-sm font-black uppercase tracking-tight truncate\">{event.title}</p>\n                      </TableCell>\n                      <TableCell>\n                        <div className=\"space-y-1\">\n                          <div className=\"flex items-center gap-2 text-[10px] font-black uppercase tracking-widest\">\n                            <Calendar className=\"h-3 w-3\" />\n                            {new Date(event.start_at).toLocaleDateString('en-GB')}\n                          </div>\n                          <div className=\"flex items-center gap-2 text-[9px] font-bold text-mono-400 uppercase\">\n                            <Clock className=\"h-3 w-3\" />\n                            {new Date(event.start_at).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' })}\n                          </div>\n                        </div>\n                      </TableCell>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2 text-[10px] font-black uppercase tracking-widest max-w-[150px] truncate\">\n                          <MapPin className=\"h-3 w-3\" />\n                          {event.location || 'REMOTE / TBA'}\n                        </div>\n                      </TableCell>\n                      <TableCell className=\"text-right pr-10\">\n                        <div className=\"flex justify-end gap-2\">\n                          <Button \n                            variant=\"ghost\" \n                            size=\"icon\" \n                            className=\"h-10 w-10 border-2 border-black rounded-none hover:bg-black hover:text-white\"\n                            onClick={() => togglePublish(event.id, event.is_published)}\n                          >\n                            <Settings2 className=\"h-4 w-4\" />\n                          </Button>\n                          <Button variant=\"ghost\" size=\"icon\" className=\"h-10 w-10 border-2 border-black rounded-none hover:bg-black hover:text-white\">\n                            <Pencil className=\"h-4 w-4\" />\n                          </Button>\n                          <Button variant=\"ghost\" size=\"icon\" className=\"h-10 w-10 border-2 border-black rounded-none hover:bg-black hover:text-white text-black\">\n                            <Trash2 className=\"h-4 w-4\" />\n                          </Button>\n                        </div>\n                      </TableCell>\n                    </TableRow>\n                  ))\n                )}\n              </TableBody>\n            </Table>\n          </div>\n        </div>\n\n        <div className=\"space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none bg-white\">\n            <CardHeader className=\"border-b-2 border-black bg-mono-50 p-8\">\n              <CardTitle className=\"text-[10px] font-black uppercase tracking-[0.4em]\">REGISTRY METRICS</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-8 space-y-10\">\n              <div className=\"space-y-2\">\n                <p className=\"text-[9px] font-black uppercase tracking-widest text-mono-400\">TOTAL EVENTS</p>\n                <p className=\"text-5xl font-black tracking-tighter\">{events.length}</p>\n              </div>\n              <div className=\"space-y-2\">\n                <p className=\"text-[9px] font-black uppercase tracking-widest text-mono-400\">ACTIVE NODES</p>\n                <p className=\"text-5xl font-black tracking-tighter\">{events.filter(e => e.is_published).length}</p>\n              </div>\n              <div className=\"p-6 bg-black text-white rounded-none border-2 border-black\">\n                <p className=\"text-[9px] font-black uppercase tracking-widest leading-relaxed\">\n                  MANAGE INSTITUTIONAL CALENDAR DATA. ENSURE ALL VENUE COORDINATES ARE VERIFIED BEFORE PUBLICATION.\n                </p>\n              </div>\n            </CardContent>\n          </Card>\n\n          <div className=\"p-8 border-4 border-black border-dashed rounded-none space-y-6 text-center bg-mono-50\">\n            <Calendar className=\"h-10 w-10 text-black mx-auto opacity-20\" />\n            <h4 className=\"text-[10px] font-black uppercase tracking-[0.4em]\">CALENDAR PROTOCOL</h4>\n            <p className=\"text-[9px] font-black uppercase tracking-widest leading-relaxed text-mono-500\">\n              EVENTS SYNC GLOBALLY TO MEMBER DASHBOARDS AND PUBLIC NODES. VERIFY ALL TIMESTAMPS AGAINST MALDIVES STANDARD TIME (GMT+5).\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(admin)\\admin\\content\\gallery\\new\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Plus' is defined but never used.","line":25,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":25,"endColumn":7,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Plus"},"fix":{"range":[530,538],"text":""},"desc":"Remove unused variable \"Plus\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'router' is assigned a value but never used.","line":39,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":39,"endColumn":15}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState } from \"react\";\nimport { createClient } from \"@/lib/supabase/client\";\nimport { useRouter } from \"next/navigation\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport { \n  Card, \n  CardContent, \n  CardDescription, \n  CardFooter, \n  CardHeader, \n  CardTitle \n} from \"@/components/ui/card\";\nimport { \n  Loader2, \n  Image as ImageIcon, \n  ArrowLeft, \n  CheckCircle2,\n  Calendar,\n  Layers,\n  ShieldCheck,\n  Plus\n} from \"lucide-react\";\nimport Link from \"next/link\";\n\nexport default function NewGalleryAlbumPage() {\n  const [loading, setLoading] = useState(false);\n  const [success, setSuccess] = useState(false);\n  const [formData, setFormData] = useState({\n    title: \"\",\n    event_date: new Date().toISOString().split('T')[0],\n    cover_image_url: \"\"\n  });\n  \n  const supabase = createClient();\n  const router = useRouter();\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setLoading(true);\n\n    const { error } = await supabase\n      .from(\"gallery_albums\")\n      .insert([\n        {\n          title: formData.title,\n          event_date: formData.event_date,\n          cover_image_url: formData.cover_image_url || null\n        }\n      ]);\n\n    if (error) {\n      alert(\"Error creating album: \" + error.message);\n    } else {\n      setSuccess(true);\n    }\n    setLoading(false);\n  };\n\n  if (success) {\n    return (\n      <div className=\"container py-24 flex items-center justify-center\">\n        <Card className=\"max-w-xl w-full text-center p-16 space-y-10 border-4 border-black bg-black text-white rounded-none shadow-[16px_16px_0px_0px_rgba(0,0,0,0.1)]\">\n          <div className=\"h-24 w-24 bg-white flex items-center justify-center mx-auto text-black border-4 border-white\">\n            <CheckCircle2 className=\"h-12 w-12\" />\n          </div>\n          <div className=\"space-y-4\">\n            <CardTitle className=\"text-4xl font-black uppercase tracking-tighter\">ALBUM CREATED</CardTitle>\n            <CardDescription className=\"text-sm font-black uppercase tracking-widest text-mono-400\">\n              VISUAL ARCHIVE VOLUME HAS BEEN INITIALIZED.\n            </CardDescription>\n          </div>\n          <Button asChild className=\"h-16 w-full bg-white text-black hover:bg-mono-200 font-black uppercase tracking-widest text-[10px] rounded-none border-2 border-white transition-all\">\n            <Link href=\"/admin/content/gallery\">RETURN TO ARCHIVE</Link>\n          </Button>\n        </Card>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"container py-24 max-w-5xl space-y-24\">\n      <Button variant=\"ghost\" className=\"text-black font-black uppercase tracking-widest text-[10px] p-0 hover:bg-transparent group\" asChild>\n        <Link href=\"/admin/content/gallery\" className=\"flex items-center\">\n          <ArrowLeft className=\"mr-3 h-5 w-5 group-hover:-translate-x-2 transition-transform\" />\n          RETURN TO VISUAL ARCHIVE\n        </Link>\n      </Button>\n\n      <div className=\"space-y-4 border-l-8 border-black pl-8\">\n        <h1 className=\"text-5xl md:text-8xl font-black uppercase tracking-tighter leading-none\">Archive <br /> Induction</h1>\n        <p className=\"text-sm font-black uppercase tracking-[0.4em] text-mono-400\">Visual Documentation Repository Protocol</p>\n      </div>\n\n      <form onSubmit={handleSubmit} className=\"grid grid-cols-1 lg:grid-cols-3 gap-16\">\n        <div className=\"lg:col-span-2 space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none overflow-hidden bg-white\">\n            <CardHeader className=\"p-10 border-b-2 border-black bg-mono-50\">\n              <CardTitle className=\"text-xs font-black uppercase tracking-[0.4em]\">VOLUME PARAMETERS</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-10 space-y-10\">\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"title\" className=\"text-[10px] font-black uppercase tracking-widest\">ALBUM TITLE / EVENT IDENTITY</Label>\n                <Input \n                  id=\"title\" \n                  placeholder=\"E.G. AAM DESIGN AWARDS 2025\" \n                  className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-sm focus-visible:ring-0\"\n                  value={formData.title}\n                  onChange={(e) => setFormData({...formData, title: e.target.value})}\n                  required\n                />\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"event_date\" className=\"text-[10px] font-black uppercase tracking-widest\">RECORDING DATE</Label>\n                <div className=\"relative\">\n                  <Calendar className=\"absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-black\" />\n                  <Input \n                    id=\"event_date\" \n                    type=\"date\"\n                    className=\"pl-14 border-2 border-black rounded-none h-14 font-black uppercase tracking-widest text-[10px] focus-visible:ring-0\"\n                    value={formData.event_date}\n                    onChange={(e) => setFormData({...formData, event_date: e.target.value})}\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"cover\" className=\"text-[10px] font-black uppercase tracking-widest\">COVER IMAGE URL (OPTIONAL)</Label>\n                <Input \n                  id=\"cover\" \n                  placeholder=\"HTTPS://...\" \n                  className=\"border-2 border-black rounded-none h-14 px-6 font-bold text-xs focus-visible:ring-0\"\n                  value={formData.cover_image_url}\n                  onChange={(e) => setFormData({...formData, cover_image_url: e.target.value})}\n                />\n              </div>\n            </CardContent>\n            <CardFooter className=\"bg-black text-white p-10 flex justify-between items-center\">\n              <div className=\"flex items-center gap-4\">\n                <ShieldCheck className=\"h-8 w-8 text-white\" />\n                <div className=\"space-y-1\">\n                  <p className=\"text-[10px] font-black uppercase tracking-widest\">ARCHIVAL INTEGRITY</p>\n                  <p className=\"text-[8px] font-bold uppercase tracking-widest text-mono-400\">VOLUME WILL BE INITIALIZED IN THE CLOUD REGISTRY.</p>\n                </div>\n              </div>\n              <Button \n                type=\"submit\" \n                disabled={loading || !formData.title || !formData.event_date}\n                className=\"h-16 px-10 bg-white text-black hover:bg-mono-200 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-white transition-all\"\n              >\n                {loading ? <Loader2 className=\"h-5 w-5 animate-spin\" /> : \"INITIALIZE VOLUME\"}\n              </Button>\n            </CardFooter>\n          </Card>\n        </div>\n\n        <div className=\"space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none bg-white\">\n            <CardHeader className=\"border-b-2 border-black p-8\">\n              <CardTitle className=\"text-[10px] font-black uppercase tracking-[0.4em]\">ASSET QUEUE</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-8 text-center space-y-6\">\n              <div className=\"aspect-square bg-mono-100 border-2 border-black border-dashed flex flex-col items-center justify-center gap-4 text-center p-6\">\n                <Layers className=\"h-8 w-8 text-mono-300\" />\n                <p className=\"text-[9px] font-black uppercase tracking-widest text-mono-400 leading-relaxed\">\n                  ASSET UPLOAD PROTOCOL REQUIRES INITIALIZED VOLUME.\n                </p>\n              </div>\n              <p className=\"text-[9px] font-bold text-mono-400 uppercase tracking-widest leading-relaxed\">\n                ASSETS CAN BE APPENDED TO THE VOLUME ONCE THE REGISTRY ENTRY IS CREATED.\n              </p>\n            </CardContent>\n          </Card>\n\n          <div className=\"p-8 border-4 border-black border-dashed rounded-none space-y-6 text-