MessageSquare\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ArrowRight' is defined but never used.","line":21,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":21,"endColumn":13,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ArrowRight"},"fix":{"range":[418,432],"text":""},"desc":"Remove unused variable \"ArrowRight\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createClient } from \"@/lib/supabase/server\";\nimport { redirect } from \"next/navigation\";\nimport { \n  Card, \n  CardContent, \n  CardDescription, \n  CardHeader, \n  CardTitle,\n  CardFooter\n} from \"@/components/ui/card\";\nimport { Badge } from \"@/components/ui/badge\";\nimport { Button } from \"@/components/ui/button\";\nimport { \n  User, \n  Award, \n  MessageSquare, \n  Bell, \n  ChevronRight,\n  FileText,\n  ShieldCheck,\n  ArrowRight\n} from \"lucide-react\";\nimport Link from \"next/link\";\n\ninterface ThreadWithAuthor {\n  id: string;\n  title: string;\n  category: string;\n  created_at: string;\n  members: { full_name: string } | null;\n}\n\n/**\n * Member Dashboard Page\n * BUG-038 FIX: Replaced hardcoded forum feed with real data from forum_threads.\n * BUG-040 FIX: Removed the non-functional \"PURGE ALL RECORDS\" button.\n * BUG-039 NOTE: CPD points remain as a placeholder (institutional tracking system in development).\n */\nexport default async function DashboardPage() {\n  const supabase = await createClient();\n  const { data: { user } } = await supabase.auth.getUser();\n\n  if (!user) {\n    redirect(\"/login\");\n  }\n\n  // 1. Fetch Member Profile\n  const { data: member } = await supabase\n    .from(\"members\")\n    .select(\"*\")\n    .eq(\"id\", user.id)\n    .single();\n\n  if (!member) {\n    redirect(\"/register?pending=true\");\n  }\n\n  // 2. Fetch Recent Forum Threads (BUG-038 FIX)\n  const { data: recentThreads } = await supabase\n    .from(\"forum_threads\")\n    .select(`\n      id, \n      title, \n      category, \n      created_at,\n      members:author_id (full_name)\n    `)\n    .eq(\"deleted_at\", null)\n    .order(\"created_at\", { ascending: false })\n    .limit(3);\n\n  return (\n    <div className=\"container py-24 space-y-24\">\n      <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-end gap-12 border-b-8 border-black pb-12\">\n        <div className=\"space-y-4\">\n          <h1 className=\"text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none\">Control <br /> Center</h1>\n          <div className=\"flex items-center gap-6\">\n            <span className=\"text-[10px] font-black uppercase tracking-[0.3em] bg-black text-white px-4 py-2\">{member.aam_id}</span>\n            <span className=\"text-[10px] font-black uppercase tracking-[0.3em] text-mono-400\">CLASS: {member.category} MEMBER</span>\n          </div>\n        </div>\n        <div className=\"flex flex-wrap gap-6\">\n          <Button variant=\"outline\" className=\"h-14 px-8 border-2 border-black rounded-none font-black uppercase tracking-widest text-[10px] hover:bg-black hover:text-white transition-all\" asChild>\n            <Link href=\"/profile\">MODIFY ARCHIVE</Link>\n          </Button>\n          <Button className=\"h-14 px-8 bg-black text-white hover:bg-mono-800 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-black transition-all\">\n            RENEW STATUS\n          </Button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-16\">\n        <div className=\"lg:col-span-2 space-y-16\">\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-10\">\n            <Card className=\"border-4 border-black rounded-none shadow-none bg-black text-white p-2\">\n              <CardHeader className=\"pb-4\">\n                <CardDescription className=\"text-mono-400 font-black uppercase tracking-[0.3em] text-[10px]\">MEMBERSHIP STATUS</CardDescription>\n                <CardTitle className=\"text-4xl font-black uppercase tracking-tighter flex items-center justify-between\">\n                  {member.status.toUpperCase()}\n                  <ShieldCheck className=\"h-8 w-8 text-white\" />\n                </CardTitle>\n              </CardHeader>\n              <CardContent>\n                <p className=\"text-[10px] font-bold uppercase tracking-widest text-mono-400 leading-relaxed\">\n                  VALIDATION EXPIRES: <br />\n                  <span className=\"text-white text-sm\">\n                    {member.renewal_date ? new Date(member.renewal_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).toUpperCase() : \"JANUARY 11, 2027\"}\n                  </span>\n                </p>\n              </CardContent>\n            </Card>\n\n            <Card className=\"border-4 border-black rounded-none shadow-none bg-white p-2\">\n              <CardHeader className=\"pb-4\">\n                <CardDescription className=\"text-mono-500 font-black uppercase tracking-[0.3em] text-[10px]\">CPD ACCRUAL (2026)</CardDescription>\n                <CardTitle className=\"text-4xl font-black uppercase tracking-tighter flex items-center justify-between text-black\">\n                  14 / 20 \n                  <Award className=\"h-8 w-8 text-black\" />\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"space-y-6\">\n                <div className=\"h-4 w-full bg-mono-100 border-2 border-black overflow-hidden\">\n                  <div className=\"h-full bg-black w-[70%]\" />\n                </div>\n                <p className=\"text-[10px] font-black uppercase tracking-widest text-mono-500 text-center\">\n                  DEFICIT: 6 POINTS FOR RENEWAL\n                </p>\n              </CardContent>\n            </Card>\n          </div>\n\n          <div className=\"space-y-10\">\n            <div className=\"flex items-baseline justify-between border-b-4 border-black pb-4\">\n              <h2 className=\"text-3xl font-black uppercase tracking-tighter\">Forum Feed</h2>\n              <Link href=\"/discussion\" className=\"text-[10px] font-black uppercase tracking-widest hover:underline decoration-2\">\n                FULL DISCOURSE\n              </Link>\n            </div>\n            \n            <div className=\"space-y-6\">\n              {recentThreads && recentThreads.length > 0 ? (\n                recentThreads.map((thread: ThreadWithAuthor) => (\n                  <Link href={`/discussion/${thread.id}`} key={thread.id}>\n                    <div className=\"group p-8 border-2 border-black rounded-none bg-white hover:bg-black hover:text-white transition-all cursor-pointer\">\n                      <div className=\"flex justify-between items-start mb-4\">\n                        <Badge className=\"bg-black text-white group-hover:bg-white group-hover:text-black rounded-none text-[9px] font-black uppercase tracking-widest border-none px-3 py-1 transition-colors\">\n                          {thread.category}\n                        </Badge>\n                        <span className=\"text-[9px] font-bold uppercase tracking-widest opacity-60\">\n                          {new Date(thread.created_at).toLocaleDateString('en-GB')}\n                        </span>\n                      </div>\n                      <h3 className=\"text-2xl font-black uppercase tracking-tighter leading-tight group-hover:underline underline-offset-4 decoration-4\">\n                        {thread.title}\n                      </h3>\n                      <div className=\"flex flex-wrap gap-8 mt-6 border-t border-black/10 group-hover:border-white/20 pt-6\">\n                        <div className=\"flex items-center gap-2 text-[10px] font-black uppercase tracking-widest opacity-60\">\n                          <User