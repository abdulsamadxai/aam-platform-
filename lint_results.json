    }\n    fetchAlbums();\n  }, [supabase]);\n\n  return (\n    <div className=\"container py-24 max-w-7xl space-y-24\">\n      <div className=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-12 border-b-8 border-black pb-12\">\n        <div className=\"space-y-4 border-l-8 border-black pl-8\">\n          <h1 className=\"text-5xl md:text-8xl font-black uppercase tracking-tighter leading-none\">Visual <br /> Archive</h1>\n          <p className=\"text-sm font-black uppercase tracking-[0.4em] text-mono-400\">Institutional Media Assets</p>\n        </div>\n        <div className=\"flex gap-4\">\n          <Button asChild className=\"h-16 px-10 bg-black text-white hover:bg-mono-800 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-black transition-all\">\n            <Link href=\"/admin/content/gallery/new\" className=\"flex items-center gap-3\">\n              <Plus className=\"h-4 w-4\" />\n              CREATE NEW ALBUM\n            </Link>\n          </Button>\n          <Button variant=\"outline\" asChild className=\"h-16 px-10 border-4 border-black text-black hover:bg-black hover:text-white rounded-none font-black uppercase tracking-widest text-[10px] transition-all\">\n            <Link href=\"/admin\">COMMAND CENTER</Link>\n          </Button>\n        </div>\n      </div>\n\n      {loading ? (\n        <div className=\"h-96 flex flex-col items-center justify-center gap-6\">\n          <Loader2 className=\"h-12 w-12 animate-spin text-black\" />\n          <span className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">MOUNTING ARCHIVAL VOLUMES...</span>\n        </div>\n      ) : albums.length === 0 ? (\n        <div className=\"h-96 border-4 border-black border-dashed flex flex-col items-center justify-center gap-6 bg-mono-50\">\n          <ImageIcon className=\"h-16 w-16 text-mono-200\" />\n          <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">NO MEDIA COLLECTIONS DETECTED.</p>\n        </div>\n      ) : (\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12\">\n          {albums.map((album) => (\n            <Card key={album.id} className=\"border-4 border-black rounded-none shadow-none overflow-hidden group hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,0.1)] transition-all\">\n              <div className=\"aspect-video bg-mono-100 border-b-4 border-black relative overflow-hidden\">\n                {album.cover_image_url ? (\n                  <img \n                    src={album.cover_image_url} \n                    alt={album.title} \n                    className=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500\"\n                  />\n                ) : (\n                  <div className=\"w-full h-full flex items-center justify-center\">\n                    <ImageIcon className=\"h-12 w-12 text-mono-300\" />\n                  </div>\n                )}\n                <div className=\"absolute top-4 right-4 flex gap-2\">\n                  <Button size=\"icon\" className=\"h-10 w-10 bg-black text-white rounded-none border-2 border-black hover:bg-mono-800\">\n                    <Pencil className=\"h-4 w-4\" />\n                  </Button>\n                  <Button size=\"icon\" className=\"h-10 w-10 bg-white text-black rounded-none border-2 border-black hover:bg-mono-100\">\n                    <Trash2 className=\"h-4 w-4\" />\n                  </Button>\n                </div>\n              </div>\n              <CardContent className=\"p-8 space-y-6\">\n                <div className=\"space-y-2\">\n                  <h3 className=\"text-xl font-black uppercase tracking-tight leading-none group-hover:underline decoration-4 underline-offset-4\">\n                    {album.title}\n                  </h3>\n                  <div className=\"flex items-center gap-4 text-[10px] font-black uppercase tracking-widest text-mono-400\">\n 