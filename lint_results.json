 CardHeader, \n  CardTitle \n} from \"@/components/ui/card\";\nimport { \n  Loader2, \n  Briefcase, \n  ArrowLeft, \n  CheckCircle2,\n  Building2,\n  CalendarDays,\n  ShieldAlert,\n  Info\n} from \"lucide-react\";\nimport Link from \"next/link\";\n\nexport default function NewJobPage() {\n  const [loading, setLoading] = useState(false);\n  const [success, setSuccess] = useState(false);\n  const [formData, setFormData] = useState({\n    title: \"\",\n    company: \"\",\n    description: \"\",\n    deadline: \"\",\n    is_active: true\n  });\n  \n  const supabase = createClient();\n  const router = useRouter();\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setLoading(true);\n\n    const { error } = await supabase\n      .from(\"job_listings\")\n      .insert([\n        {\n          title: formData.title,\n          company: formData.company,\n          description: formData.description,\n          deadline: formData.deadline || null,\n          is_active: formData.is_active\n        }\n      ]);\n\n    if (error) {\n      alert(\"Error posting vacancy: \" + error.message);\n    } else {\n      setSuccess(true);\n    }\n    setLoading(false);\n  };\n\n  if (success) {\n    return (\n      <div className=\"container py-24 flex items-center justify-center\">\n        <Card className=\"max-w-xl w-full text-center p-16 space-y-10 border-4 border-black bg-black text-white rounded-none shadow-[16px_16px_0px_0px_rgba(0,0,0,0.1)]\">\n          <div className=\"h-24 w-24 bg-white flex items-center justify-center mx-auto text-black border-4 border-white\">\n            <CheckCircle2 className=\"h-12 w-12\" />\n          </div>\n          <div className=\"space-y-4\">\n            <CardTitle className=\"text-4xl font-black uppercase tracking-tighter\">VACANCY DISPATCHED</CardTitle>\n            <CardDescription className=\"text-sm font-black uppercase tracking-widest text-mono-400\">\n              PROFESSIONAL OPPORTUNITY HAS BEEN SYNCHRONIZED TO THE PUBLIC PORTAL.\n            </CardDescription>\n          </div>\n          <Button asChild className=\"h-16 w-full bg-white text-black hover:bg-mono-200 font-black uppercase tracking-widest text-[10px] rounded-none border-2 border-white transition-all\">\n            <Link href=\"/admin/content/jobs\">RETURN TO PORTAL</Link>\n          </Button>\n        </Card>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"container py-24 max-w-5xl space-y-24\">\n      <Button variant=\"ghost\" className=\"text-black font-black uppercase tracking-widest text-[10px] p-0 hover:bg-transparent group\" asChild>\n        <Link href=\"/admin/content/jobs\" className=\"flex items-center\">\n          <ArrowLeft className=\"mr-3 h-5 w-5 group-hover:-translate-x-2 transition-transform\" />\n          RETURN TO VACANCY PORTAL\n        </Link>\n      </Button>\n\n      <div className=\"space-y-4 border-l-8 border-black pl-8\">\n        <h1 className=\"text-5xl md:text-8xl font-black uppercase tracking-tighter leading-none\">Vacancy <br /> Induction</h1>\n        <p className=\"text-sm font-black uppercase tracking-[0.4em] text-mono-400\">Professional Opportunity Registry Protocol</p>\n      </div>\n\n      <form onSubmit={handleSubmit} className=\"grid grid-cols-1 lg:grid-cols-3 gap-16\">\n        <div className=\"lg:col-span-2 space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none overflow-hidden bg-white\">\n            <CardHeader className=\"p-10 border-b-2 border-black bg-mono-50\">\n              <CardTitle className=\"text-xs font-black uppercase tracking-[0.4em]\">OPPORTUNITY PARAMETERS</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-10 space-y-10\">\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"title\" className=\"text-[10px] font-black uppercase tracking-widest\">POSITION TITLE</Label>\n                <Input \n                  id=\"title\" \n                  placeholder=\"E.G. SENIOR ARCHITECTURAL ASSOCIATE\" \n                  className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-sm focus-visible:ring-0\"\n                  value={formData.title}\n                  onChange={(e) => setFormData({...formData, title: e.target.value})}\n                  required\n                />\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"company\" className=\"text-[10px] font-black uppercase tracking-widest\">CONTRACTING ENTITY (FIRM NAME)</Label>\n                <div className=\"relative\">\n                  <Building2 className=\"absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-black\" />\n                  <Input \n                    id=\"company\" \n                    placeholder=\"E.G. ARCHI-STUDIO MALDIVES\" \n                    className=\"pl-14 border-2 border-black rounded-none h-14 font-bold uppercase tracking-widest text-xs focus-visible:ring-0\"\n                    value={formData.company}\n                    onChange={(e) => setFormData({...formData, company: e.target.value})}\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"description\" className=\"text-[10px] font-black uppercase tracking-widest\">ROLE SPECIFICATIONS & REQUIREMENTS</Label>\n                <Textarea \n                  id=\"description\" \n                  placeholder=\"PROVIDE COMPREHENSIVE TERMS OF REFERENCE...\" \n                  className=\"border-2 border-black rounded-none p-6 font-bold uppercase tracking-widest text-xs focus-visible:ring-0 min-h-[200px]\"\n                  value={formData.description}\n                  onChange={(e) => setFormData({...formData, description: e.target.value})}\n                  required\n                />\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"deadline\" className=\"text-[10px] font-black uppercase tracking-widest\">SUBMISSION DEADLINE</Label>\n                <div className=\"relative\">\n                  <CalendarDays className=\"absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-black\" />\n                  <Input \n                    id=\"deadline\" \n                    type=\"date\"\n                    className=\"pl-14 border-2 border-black rounded-none h-14 font-black uppercase tracking-widest text-[10px] focus-visible:ring-0\"\n                    value={formData.deadline}\n                    onChange={(e) => setFormData({...formData, deadline: e.target.value})}\n                  />\n                </div>\n              </div>\n            </CardContent>\n            <CardFooter className=\"bg-black text-white p-10 flex justify-between items-center\">\n              <div className=\"flex items-center gap-4\">\n                <ShieldAlert className=\"h-8 w-8 text-white\" />\n                <div className=\"space-y-1\">\n                  <p className=\"text-[10px] font-black uppercase tracking-widest\">REGISTRY INTEGRITY</p>\n                  <p className=\"text-[8px] font-bold uppercase tracking-widest text-mono-400\">LISTING WILL BE VISIBLE TO ALL NODES.</p>\n                </div>\n              </div>\n              <Button \n                type=\"submit\" \n                disabled={loading || !formData.title || !formData.company || !formData.description}\n                className=\"h-16 px-10 bg-white text-black hover:bg-mono-200 rounded-none font-black uppercase tracking-widest text-[10px] border-2 border-white transition-all\"\n              >\n                {loading ? <Loader2 className=\"h-5 w-5 animate-spin\" /> : \"PUBLISH VACANCY\"}\n              </Button>\n            </CardFooter>\n          </Card>\n        </div>\n\n        <div className=\"space-y-12\">\n          <Card className=\"border-4 border-black rounded-none shadow-none bg-white\">\n            <CardHeader className=\"border-b-2 border-black p-8\">\n              <CardTitle className=\"text-[10px] font-black uppercase tracking-[0.4em]\">LISTING PROTOCOL</CardTitle>\n            </CardHeader>\n            <CardContent className=\"p-8 space-y-6\">\n              <div className=\"flex items-center gap-4 p-6 bg-mono-50 border-2 border-black/5\">\n                <input \n                  type=\"checkbox\" \n                  id=\"active\" \n                  checked={formData.is_active}\n                  onChange={(e) => setFormData({...formData, is_active: e.target.checked})}\n                  className=\"h-5 w-5 text-black border-2 border-black rounded-none focus:ring-0\"\n                />\n                <Label htmlFor=\"active\" className=\"text-[10px] font-black uppercase tracking-widest cursor-pointer\">\n                  ACTIVATE ON DISPATCH\n                </Label>\n              </div>\n              <div className=\"p-6 border-2 border-black bg-white rounded-none space-y-2\">\n                <div className=\"flex items-center gap-2 text-[10px] font-black uppercase tracking-widest\">\n                  <Info className=\"h-4 w-4\" />\n                  AUDIT COMPLIANCE\n                </div>\n                <p className=\"text-[8px] font-bold uppercase tracking-widest text-mono-400\">ENSURE COMPLIANCE WITH MALDIVES LABOR LAWS AND AAM ETHICS CODE.</p>\n              </div>\n            </CardContent>\n          </Card>\n\n          <div className=\"p-8 border-4 border-black border-dashed rounded-none space-y-6 bg-mono-50 text-center\">\n            <Briefcase className=\"h-10 w-10 text-black mx-auto opacity-20\" />\n            <h4 className=\"text-[10px] font-black uppercase tracking-[0.4em]\">PROFESSIONAL NOTICE</h4>\n            <p className=\"text-[9px] font-black uppercase tracking-widest leading-relaxed text-mono-500\">\n              VACANCIES REMAIN ACTIVE UNTIL THE DEADLINE TRANSPIRES OR ARE MA