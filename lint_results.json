ame=\"flex flex-col items-center justify-center gap-6\">\n                        <Loader2 className=\"h-10 w-10 animate-spin text-black\" />\n                        <span className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">SCANNING OPPORTUNITY NODES...</span>\n                      </div>\n                    </TableCell>\n                  </TableRow>\n                ) : jobs.length === 0 ? (\n                  <TableRow>\n                    <TableCell colSpan={5} className=\"h-64 text-center\">\n                      <p className=\"text-[10px] font-black uppercase tracking-[0.4em] text-mono-400\">NO ACTIVE VACANCIES REGISTERED.</p>\n                    </TableCell>\n                  </TableRow>\n                ) : (\n                  jobs.map((job) => (\n                    <TableRow key={job.id} className=\"border-b-2 border-black/5 last:border-none hover:bg-mono-50 transition-colors\">\n                      <TableCell className=\"pl-10 py-8\">\n                        {job.is_active ? (\n                          <div className=\"flex items-center gap-2 text-black font-black uppercase text-[10px] tracking-widest\">\n                            <CheckCircle2 className=\"h-4 w-4\" />\n                            ACTIVE\n                          </div>\n                        ) : (\n                          <div className=\"flex items-center gap-2 text-mono-400 font-black uppercase text-[10px] tracking-widest\">\n                            <XCircle className=\"h-4 w-4\" />\n                            CLOSED\n                          </div>\n                        )}\n                      </TableCell>\n                      <TableCell className=\"max-w-xs\">\n                        <p className=\"text-sm font-black uppercase tracking-tight truncate\">{job.title}</p>\n                        <div className=\"flex items-center gap-2 mt-1\">\n                          <Building2 className=\"h-3 w-3 text-mono-400\" />\n        