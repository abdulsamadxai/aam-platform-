elative h-screen flex items-center justify-center overflow-hidden\">\n        {/* Parallax Background */}\n        <div \n          className=\"absolute inset-0 z-0 scale-110\"\n          style={{ \n            backgroundImage: `url('https://images.unsplash.com/photo-1590523277543-a94d2e4eb00b?q=80&w=2070')`,\n            backgroundSize: 'cover',\n            backgroundPosition: 'center',\n            transform: `translateY(${scrollY * 0.4}px)`\n          }}\n        />\n        <div className=\"absolute inset-0 z-10 hero-overlay\" />\n        \n        {/* Wave Separator */}\n        <div className=\"absolute bottom-0 left-0 right-0 h-32 z-20 wave-separator opacity-20 pointer-events-none\" />\n\n        <div className=\"container relative z-30 text-center space-y-8 max-w-5xl\">\n          <div className=\"space-y-4 animate-in fade-in slide-in-from-bottom-8 duration-1000\">\n            <div className=\"h-[2px] w-24 bg-aam-gold mx-auto mb-6\" />\n            <h1 className=\"text-aam-sand font-display font-bold leading-[1.1] tracking-tight [text-shadow:1px_1px_0px_#00A499] text-[clamp(48px,8vw,96px)]\">\n              Shaping the <br /> <span className=\"italic\">Maldivian Atolls.</span>\n            </h1>\n            <p className=\"text-aam-sand/85 font-sans font-light text-xl md:text-2xl tracking-wide max-w-3xl mx-auto uppercase\">\n              The statutory authority for professional architectural and urban planning standards in the Republic of Maldives.\n            </p>\n          </div>\n\n          <div className=\"flex flex-col sm:flex-row items-center justify-center gap-6 pt-12 animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-500\">\n            <Link href=\"/registration\" className=\"btn-teal\">Register as Architect</Link>\n            <Link href=\"/about\" className=\"btn-ghost-white\">Learn More</Link>\n          </div>\n        </div>\n\n        {/* Floating Stat Bar */}\n        <div className=\"absolute bottom-12 left-1/2 -translate-x-1/2 w-full max-w-5xl px-6 z-30 animate-in fade-in slide-in-from-bottom-16 duration-1000 delay-1000\">\n          <div className=\"bg-aam-navy/80 backdrop-blur-xl border border-aam-gold/20 grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-aam-gold/10 p-8\">\n            {[\n              { label: \"Registered Architects\", value: \"350+\", icon: Users },\n              { label: \"Licensed Firms\", value: \"85+\", icon: Building2 },\n              { label: \"Years of Excellence\", value: \"32\", icon: Award }\n            ].map((stat, i) => (\n              <div key={i} className=\"flex items-center justify-center gap-6 p-4\">\n                <stat.icon className=\"h-8 w-8 text-aam-teal\" />\n                <div className=\"text-left\">\n                  <div className=\"text-3xl font-display font-bold text-aam-sand\">{stat.value}</div>\n                  <div className=\"text-[10px] font-sans font-medium uppercase tracking-[0.2em] text-aam-gold/70\">{stat.label}</div>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* 2. ABOUT EXCERPT SECTION */}\n      <section className=\"py-32 bg-aam-sand coral-motif relative\">\n        <div className=\"container\">\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-24 items-center\">\n            <div className=\"lg:col-span-7 space-y-12 border-l-4 border-aam-gold pl-12\">\n              <div className=\"space-y-4\">\n                <span className=\"text-aam-teal font-mono text-sm tracking-[0.4em] uppercase\">Institutional Identity</span>\n                <h2 className=\"text-aam-navy text-5xl md:text-6xl font-display font-bold leading-tight\">\n                  Custodian of Professional <br /> Standards & Ethics.\n                </h2>\n              </div>\n              <div className=\"space-y-8\">\n                <p className=\"text-lg\">\n                  Established to regulate the profession of architecture and town planning, the Architects Association of Maldives (AAM) serves as the primary governing body for professional practice in the archipelago. We are committed to fostering architectural excellence that respects our maritime heritage while embracing global innovation.\n                </p>\n                <blockquote className=\"text-2xl font-display italic text-aam-navy/80 leading-relaxed py-8 border-y border-aam-navy/5\">\n                  &quot;Architecture in the Maldives is a dialogue between the coral reef and the horizon. We exist to ensure that dialogue is one of integrity and brilliance.&quot;\n                </blockquote>\n                <Link href=\"/about\" className=\"inline-flex items-center gap-4 text-aam-teal font-sans font-bold uppercase tracking-widest text-xs border-b border-aam-teal pb-2 hover:gap-6 transition-all\">\n                  Read Full History <ArrowRight className=\"h-4 w-4\" />\n                </Link>\n              </div>\n            </div>\n            <div className=\"lg:col-span-5 relative\">\n              <div className=\"aspect-[4/5] bg-aam-navy overflow-hidden group\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1544911845-1f34a3eb46b1?q=80&w=2070\" \n                  alt=\"Hukuru Miskiy Coral Architecture\"\n                  className=\"w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105\"\n                />\n              </div>\n              {/* Decorative Atoll Map Overlay */}\n              <div className=\"absolute -bottom-12 -right-12 h-48 w-48 bg-aam-gold/10 backdrop-blur-xl border border-aam-gold/20 p-8 flex items-center justify-center\">\n                <MapPin className=\"h-12 w-12 text-aam-gold opacity-30\" />\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* 3. LATEST BULLETINS SECTION */}\n      <section className=\"py-32 bg-aam-navy text-aam-sand\">\n        <div className=\"container space-y-16\">\n          <div className=\"flex flex-col md:flex-row justify-between items-end gap-8\">\n            <div className=\"space-y-4\">\n              <span className=\"text-aam-teal font-mono text-sm tracking-[0.4em] uppercase\">Registry Bulletins</span>\n              <h2 className=\"text-4xl md:text-6xl font-display font-bold leading-tight\">News & <span className=\"italic\">Announcements.</span></h2>\n            </div>\n            <Link href=\"/news\" className=\"btn-ghost-white\">View All Reports</Link>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n            {[1, 2, 3].map((item) => (\n              <div key={item} className=\"group bg-aam-sand p-10 border border-aam-gold/20 hover:border-aam-teal transition-all duration-500 relative\">\n                <div className=\"absolute top-0 left-0 px-4 py-1 bg-aam-teal text-aam-sand text-[10px] font-sans font-bold uppercase tracking-widest\">\n                  Official Notice\n                </div>\n                <div className=\"space-y-6 pt-4\">\n                  <div className=\"flex items-center justify-between text-aam-gray font-mono text-[11px] uppercase tracking-widest\">\n                    <span>21 APR 2026</span>\n                    <span>#B-442</span>\n                  </div>\n                  <h3 className=\"text-aam-navy text-2xl font-display font-bold leading-tight group-hover:text-aam-teal transition-colors\">\n                    Professional Practice Examination (PPE) 2026 Batch Results Announcement.\n                  </h3>\n                  <p className=\"text-aam-midnight/60 text-sm line-clamp-3\">\n                    The Secretariat is pleased to announce the successful verification of the 2026 batch candidates for professional registration...\n                  </p>\n                  <Link href=\"/news/post\" className=\"inline-flex items-center gap-3 text-aam-navy font-sans font-bold uppercase tracking-widest text-[10px] hover:text-aam-teal transition-colors\">\n                    Access Report <ArrowUpRight className=\"h-4 w-4\" />\n                  </Link>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* 4. CALL TO ACTION BAND */}\n      <section className=\"py-24 bg-aam-gold relative overflow-hidden\">\n        <div className=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]\" />\n        <div className=\"container relative z-10 flex flex-col md:flex-row items-center justify-between gap-12 text-aam-navy\">\n          <div className=\"space-y-4 max-w-2xl text-center md:text-left\">\n            <h2 className=\"text-4xl font-display font-bold italic tracking-tight\">Become a Registered Member</h2>\n            <p className=\"text-lg font-sans font-medium uppercase tracking-tight opacity-70\">\n              Uphold the highest standards of architectural practice in the Maldives.\n            </p>\n          </div>\n          <button className=\"bg-aam-navy text-aam-sand px-12 py-6 font-sans font-bold uppercase tracking-[0.3em] text-xs hover:bg-aam-teal transition-all\">\n            Initiate Registration\n          </button>\n        </div>\n      </section>\n    </main>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\register\\page.tsx","messages":[{"ruleId":"react-hooks/incompatible-library","severity":1,"message":"Compilation Skipped: Use of incompatible library\n\nThis API returns functions which cannot be memoized without leading to stale UI. To prevent this, by default React Compiler will skip memoizing this component/hook. However, you may see issues if values from this API are passed to other components/hooks that are memoized.\n\nC:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\register\\page.tsx:49:27\n  47 |   });\n  48 |\n> 49 |   const categoryApplied = watch(\"category_applied\");\n     |                           ^^^^^ React Hook Form's `useForm()` API returns a `watch()` function which cannot be memoized safely.\n  50 |\n  51 |   const onSubmit = async (data: RegistrationInput) => {\n  52 |     setIsSubmitting(true);","line":49,"column":27,"nodeType":null,"endLine":49,"endColumn":32},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":140,"column":79,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":140,"endColumn":82,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[5964,5967],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[5964,5967],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { useState } from \"react\";\nimport { useForm } from \"react-hook-form\";\nimport { zodResolver } from \"@hookform/resolvers/zod\";\nimport { registrationSchema, RegistrationInput } from \"@/lib/validations\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui/select\";\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from \"@/components/ui/card\";\nimport { Label } from \"@/components/ui/label\";\nimport { Textarea } from \"@/components/ui/textarea\";\nimport { createClient } from \"@/lib/supabase/client\";\nimport Link from \"next/link\";\nimport { CheckCircle2, Loader2, ArrowRight } from \"lucide-react\";\n\n\nexport default function RegisterPage() {\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [isSuccess, setIsSuccess] = useState(false);\n  const supabase = createClient();\n\n  const {\n    register,\n    handleSubmit,\n    setValue,\n    watch,\n    formState: { errors },\n  } = useForm<RegistrationInput>({\n    resolver: zodResolver(registrationSchema),\n    defaultValues: {\n      category_applied: \"professional\",\n    },\n  });\n\n  const categoryApplied = watch(\"category_applied\");\n\n  const onSubmit = async (data: RegistrationInput) => {\n    setIsSubmitting(true);\n    const { error } = await supabase\n      .from(\"registration_applications\")\n      .insert([data]);\n\n    if (error) {\n      alert(\"Error submitting application: \" + error.message);\n    } else {\n      setIsSuccess(true);\n    }\n    setIsSubmitting(false);\n  };\n\n  if (isSuccess) {\n    return (\n      <div className=\"container py-32 flex items-center justify-center\">\n        <Card className=\"max-w-md w-full border-4 border-black rounded-none shadow-none bg-black text-white p-12 text-center space-y-8\">\n          <div className=\"flex justify-center\">\n            <div className=\"h-20 w-20 bg-white flex items-center justify-center text-black\">\n              <CheckCircle2 className=\"h-10 w-10\" />\n            </div>\n          </div>\n          <div className=\"space-y-4\">\n            <CardTitle className=\"text-3xl font-black uppercase tracking-tighter\">SUBMITTED</CardTitle>\n            <CardDescription className=\"text-mono-400 font-medium text-lg leading-tight\">\n              Institutional review in progress. We will contact you at {watch(\"email\")} once verified.\n            </CardDescription>\n          </div>\n          <CardFooter className=\"flex justify-center p-0 pt-4\">\n            <Button asChild className=\"bg-white text-black hover:bg-mono-200 rounded-none font-black uppercase tracking-widest text-xs px-10 py-6 h-auto\">\n              <Link href=\"/\">RETURN TO SITE</Link>\n            </Button>\n          </CardFooter>\n        </Card>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"container py-24 flex justify-center\">\n      <div className=\"max-w-3xl w-full space-y-16\">\n        <div className=\"space-y-6 border-l-8 border-black pl-8\">\n          <h1 className=\"font-display text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none\">Enrollment <br /> Protocol</h1>\n          <p className=\"text-xl text-mono-500 font-medium max-w-xl leading-tight\">\n            Initiate your formal registration with the Architects Association Maldives. \n            All applications are subject to executive committee audit.\n          </p>\n        </div>\n\n        <form onSubmit={handleSubmit(onSubmit)}>\n          <Card className=\"border-4 border-black rounded-none shadow-none bg-white overflow-hidden\">\n            <CardHeader className=\"p-10 border-b-2 border-black bg-mono-50\">\n              <CardTitle className=\"text-xs font-black uppercase tracking-[0.4em]\">REGISTRATION DOSSIER</CardTitle>\n              <CardDescription className=\"text-[10px] font-bold text-mono-400 uppercase tracking-widest mt-2\">Personal & Professional Credentials</CardDescription>\n            </CardHeader>\n            <CardContent className=\"p-10 space-y-10\">\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-10\">\n                <div className=\"space-y-3\">\n                  <Label htmlFor=\"applicant_name\" className=\"text-[10px] font-black uppercase tracking-widest\">Full Name (Legal)</Label>\n                  <Input \n                    id=\"applicant_name\" \n                    placeholder=\"ENTER FULL NAME\" \n                    className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300\"\n                    {...register(\"applicant_name\")} \n                  />\n                  {errors.applicant_name && (\n                    <p className=\"text-[10px] font-black text-black uppercase\">{errors.applicant_name.message}</p>\n                  )}\n                </div>\n                <div className=\"space-y-3\">\n                  <Label htmlFor=\"email\" className=\"text-[10px] font-black uppercase tracking-widest\">Digital Contact (Email)</Label>\n                  <Input \n                    id=\"email\" \n                    type=\"email\" \n                    placeholder=\"YOU@EXAMPLE.MV\" \n                    className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300\"\n                    {...register(\"email\")} \n                  />\n                  {errors.email && (\n                    <p className=\"text-[10px] font-black text-black uppercase\">{errors.email.message}</p>\n                  )}\n                </div>\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"category_applied\" className=\"text-[10px] font-black uppercase tracking-widest\">Membership Classification</Label>\n                <Select \n                  defaultValue=\"professional\" \n                  onValueChange={(val) => setValue(\"category_applied\", val as any)}\n                >\n                  <SelectTrigger id=\"category_applied\" className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-xs focus:ring-0\">\n                    <SelectValue placeholder=\"SELECT CLASSIFICATION\" />\n                  </SelectTrigger>\n                  <SelectContent className=\"rounded-none border-2 border-black shadow-none font-bold uppercase text-xs\">\n                    <SelectItem value=\"professional\">PROFESSIONAL MEMBER</SelectItem>\n                    <SelectItem value=\"general\">GENERAL MEMBER</SelectItem>\n                    <SelectItem value=\"associate\">ASSOCIATE MEMBER</SelectItem>\n                  </SelectContent>\n                </Select>\n                {errors.category_applied && (\n                  <p className=\"text-[10px] font-black text-black uppercase\">{errors.category_applied.message}</p>\n                )}\n                <div className=\"p-4 bg-mono-50 border-l-4 border-black\">\n                   <p className=\"text-[10px] font-bold text-mono-600 uppercase tracking-widest leading-tight\">\n                    {categoryApplied === 'professional' && \"Criterion: Recognized architecture degree + documented professional practice.\"}\n                    {categoryApplied === 'general' && \"Criterion: Architectural qualifications currently awaiting professional practice duration.\"}\n                    {categoryApplied === 'associate' && \"Criterion: Active students or professionals in allied design disciplines.\"}\n                  </p>\n                </div>\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"documents_url\" className=\"text-[10px] font-black uppercase tracking-widest\">Credentials Link (Portfolio/ID)</Label>\n                <Input \n                  id=\"documents_url\" \n                  placeholder=\"URL TO CLOUD STORAGE (DRIVE/DROPBOX)\" \n                  className=\"border-2 border-black rounded-none h-14 px-6 font-bold uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300\"\n                  {...register(\"documents_url\")} \n                />\n                {errors.documents_url && (\n                  <p className=\"text-[10px] font-black text-black uppercase\">{errors.documents_url.message}</p>\n                )}\n              </div>\n\n              <div className=\"space-y-3\">\n                <Label htmlFor=\"notes\" className=\"text-[10px] font-black uppercase tracking-widest\">Supplemental Briefing</Label>\n                <Textarea \n                  id=\"notes\" \n                  placeholder=\"PROVIDE ADDITIONAL CONTEXT FOR THE COMMITTEE...\" \n                  className=\"min-h-[160px] border-2 border-black rounded-none px-6 py-4 font-bold uppercase tracking-widest text-xs focus-visible:ring-0 placeholder:text-mono-300 resize-none\"\n                  {...register(\"notes\")} \n                />\n                {errors.notes && (\n                  <p className=\"text-[10px] font-black text-black uppercase\">{errors.notes.message}</p>\n                )}\n              </div>\n            </CardContent>\n            <CardFooter className=\"bg-black text-white flex flex-col md:flex-row justify-between items-center p-10 gap-8\">\n              <p className=\"text-[10px] font-bold uppercase tracking-[0.2em] max-w-sm leading-relaxed opacity-60\">\n                BY DISPATCHING THIS DOSSIER, YOU FORMALLY ADHERE TO THE AAM ARCHITECTURAL CODE OF CONDUCT AND ETHICAL STANDARDS.\n              </p>\n              <Button \n                type=\"submit\" \n                disabled={isSubmitting} \n                className=\"bg-white text-black hover:bg-mono-200 font-black uppercase tracking-[0.3em] h-16 px-12 rounded-none transition-all group border-2 border-white min-w-[240px] text-xs\"\n              >\n                {isSubmitting ? (\n                  <>\n                    <Loader2 className=\"mr-3 h-5 w-5 animate-spin\" />\n                    DISPATCHING...\n                  </>\n                ) : (\n                  <>\n                    SUBMIT DOSSIER\n                    <ArrowRight className=\"ml-3 h-5 w-5 group-hover:translate-x-2 transition-transform\" />\n                  </>\n                )}\n              </Button>\n            </CardFooter>\n          </Card>\n        </form>\n      </div>\n    </div>\n  );\n}\n\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\abdul\\Desktop\\Maldives Architecture\\aam-platform\\app\\(public)\\training\\page.tsx","mes